lemma E4_refresh_requires_issuance:
  all-traces
  "∀ token ClientID pkC #i.
    (RefreshToken_Used( token, ClientID, pkC ) @ #i) ⇒
    (∃ #j.
      (RefreshToken_Issued( token, ClientID, pkC ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ token ClientID pkC #i.
  (RefreshToken_Used( token, ClientID, pkC ) @ #i)
 ∧
  ∀ #j.
   (RefreshToken_Issued( token, ClientID, pkC ) @ #j) ⇒ ¬(#j < #i)"
*/
simplify
by contradiction /* from formulas */

lemma ISS1_consistency [hide_lemma=R2_dpop_requires_creation,
                        hide_lemma=B1_attestation_unforgeable,
                        hide_lemma=B2_as_requires_attestation,
                        hide_lemma=B3_token_implies_attestation,
                        hide_lemma=accept_implies_hardware,
                        hide_lemma=I1_token_requires_hardware_key]:
  all-traces
  "∀ ClientID iss #i.
    (Client_Verified_Iss( ClientID, iss ) @ #i) ⇒
    (∃ #j. (Client_Learned_Iss( ClientID, iss ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID iss #i.
  (Client_Verified_Iss( ClientID, iss ) @ #i)
 ∧
  ∀ #j. (Client_Learned_Iss( ClientID, iss ) @ #j) ⇒ ¬(#j < #i)"
*/
simplify
solve( !Client_Key( ClientID, skC, pkC ) ▶₁ #i )
  case Client_GenerateKey_ToClient_Step4
  solve( !Client_Expected_Iss( ClientID, iss ) ▶₂ #i )
    case Client_GenerateKey_ToClient_Step4
    by contradiction /* from formulas */
  qed
qed

lemma ISS2_no_mix_up [hide_lemma=R2_dpop_requires_creation,
                      hide_lemma=B1_attestation_unforgeable,
                      hide_lemma=B2_as_requires_attestation,
                      hide_lemma=B3_token_implies_attestation,
                      hide_lemma=accept_implies_hardware,
                      hide_lemma=I1_token_requires_hardware_key]:
  all-traces
  "∀ code ClientID pkC iss1 iss2 #i #j.
    (((AuthzCode_Issued( code, ClientID, pkC, iss1 ) @ #i) ∧
      (AuthzCode_Redeemed( code, ClientID, pkC ) @ #j)) ∧
     (Token_Issued_By_Iss( ClientID, iss2 ) @ #j)) ⇒
    (iss1 = iss2)"
/*
guarded formula characterizing all counter-examples:
"∃ code ClientID pkC iss1 iss2 #i #j.
  (AuthzCode_Issued( code, ClientID, pkC, iss1 ) @ #i) ∧
  (AuthzCode_Redeemed( code, ClientID, pkC ) @ #j) ∧
  (Token_Issued_By_Iss( ClientID, iss2 ) @ #j)
 ∧
  ¬(iss1 = iss2)"
*/
simplify
solve( !AS_StoredCredentials( password ) ▶₁ #i )
  case Setup_User_Credentials
  solve( !AS_Client_Tied_PublicKey( ClientID, pk(x), iss1 ) ▶₂ #i )
    case AS_VerifyJWTAndDPoPP_ToBackend_Step10
    solve( AuthzCode( ~authorization_code, ~ClientID, pk(x), iss2
           ) ▶₁ #j )
      case AS_VerifyROPC_SendCode_ROPCStep5_6
      by contradiction /* from formulas */
    qed
  qed
qed

lemma ISS3_token_origin [hide_lemma=R2_dpop_requires_creation,
                         hide_lemma=B1_attestation_unforgeable,
                         hide_lemma=B2_as_requires_attestation,
                         hide_lemma=B3_token_implies_attestation,
                         hide_lemma=accept_implies_hardware,
                         hide_lemma=I1_token_requires_hardware_key]:
  all-traces
  "∀ ClientID iss #i.
    (Token_Issued_By_Iss( ClientID, iss ) @ #i) ⇒
    (∃ code pkC #j.
      (AuthzCode_Issued( code, ClientID, pkC, iss ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID iss #i.
  (Token_Issued_By_Iss( ClientID, iss ) @ #i)
 ∧
  ∀ code pkC #j.
   (AuthzCode_Issued( code, ClientID, pkC, iss ) @ #j) ⇒ ¬(#j < #i)"
*/
simplify
solve( AuthzCode( authorization_code, ClientID, pk(x), iss
       ) ▶₁ #i )
  case AS_VerifyROPC_SendCode_ROPCStep5_6
  by contradiction /* from formulas */
qed

lemma ISS4_client_rejects_wrong_iss [hide_lemma=R2_dpop_requires_creation,
                                     hide_lemma=B1_attestation_unforgeable,
                                     hide_lemma=B2_as_requires_attestation,
                                     hide_lemma=B3_token_implies_attestation,
                                     hide_lemma=accept_implies_hardware,
                                     hide_lemma=I1_token_requires_hardware_key]:
  all-traces
  "∀ ClientID iss_learned iss_verified #i #j.
    (((Client_Learned_Iss( ClientID, iss_learned ) @ #i) ∧
      (Client_Verified_Iss( ClientID, iss_verified ) @ #j)) ∧
     (#i < #j)) ⇒
    (iss_learned = iss_verified)"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID iss_learned iss_verified #i #j.
  (Client_Learned_Iss( ClientID, iss_learned ) @ #i) ∧
  (Client_Verified_Iss( ClientID, iss_verified ) @ #j)
 ∧
  (#i < #j) ∧ (¬(iss_learned = iss_verified))"
*/
simplify
solve( !Client_Key( ClientID, skC.1, pkC ) ▶₁ #j )
  case Client_GenerateKey_ToClient_Step4
  solve( !Client_Expected_Iss( ClientID, iss_verified ) ▶₂ #j )
    case Client_GenerateKey_ToClient_Step4
    by contradiction /* from formulas */
  qed
qed

lemma ISS5_refresh_preserves_iss [hide_lemma=R2_dpop_requires_creation,
                                  hide_lemma=B1_attestation_unforgeable,
                                  hide_lemma=B2_as_requires_attestation,
                                  hide_lemma=B3_token_implies_attestation,
