rule (modulo E) Backend_RequestDPoP_ForTokenExchange[role=Backend]:
   [
   In_S( $AS, $Backend,
         <'auth_completed_as2b', ClientID, authorization_code>
   )
   ]
  -->
   [
   Out_S( $Backend, $Client, <'dpop_needed_for_token_b2c', ClientID>
   ),
   Backend_PendingTokenExchange( ClientID, authorization_code )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Client_CreateDPoP_ForTokenExchange[role=Client]:
   [
   In_S( $Backend, $Client, <'dpop_needed_for_token_b2c', ClientID> ),
   !Client_Key( ClientID, skC, pkC ), Fr( ~DPoP_Params_TE )
   ]
  --[ Client_Created_DPoP( pkC, ~DPoP_Params_TE, 'token_te' ) ]->
   [
   Out_S( $Client, $Backend,
          <'dpop_for_token_c2b', 
           sign(<~DPoP_Params_TE, 'token_endpoint'>, skC), pkC, 
           ~DPoP_Params_TE, ClientID>
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Backend_TokenRequest_ToAS_Step12[role=Backend]:
