lemma T5_stolen_refresh_needs_dpop:
  all-traces
  "∀ token pkC ClientID #i #j.
    ((LeakRefreshToken( token, pkC ) @ #i) ∧
     (RefreshToken_Used( token, ClientID, pkC ) @ #j)) ⇒
    ((∃ params ctx #k #l.
       (((Client_Created_DPoP( pkC, params, ctx ) @ #k) ∧
         (DPoP_Verified( params, pkC ) @ #l)) ∧
        (#k < #l)) ∧
       (#l = #j)) ∨
     (∃ skC #r. RevealClientKey( ClientID, skC ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ token pkC ClientID #i #j.
  (LeakRefreshToken( token, pkC ) @ #i) ∧
  (RefreshToken_Used( token, ClientID, pkC ) @ #j)
 ∧
  (∀ params ctx #k #l.
    (Client_Created_DPoP( pkC, params, ctx ) @ #k) ∧
    (DPoP_Verified( params, pkC ) @ #l) ∧
    (#l = #j)
   ⇒
    ¬(#k < #l)) ∧
  (∀ skC #r. (RevealClientKey( ClientID, skC ) @ #r) ⇒ ⊥)"
*/
simplify
solve( !ConstrainedRefresh( ~refresh_token, pk(x) ) ▶₀ #i )
