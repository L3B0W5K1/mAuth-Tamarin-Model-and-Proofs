lemma SANITY_full_chain [hide_lemma=R2_dpop_requires_creation,
                         hide_lemma=B1_attestation_unforgeable,
                         hide_lemma=B2_as_requires_attestation,
                         hide_lemma=B3_token_implies_attestation,
                         hide_lemma=accept_implies_hardware,
                         hide_lemma=I1_token_requires_hardware_key,
                         hide_lemma=accept_unique_pkC, hide_lemma=client_iss_unique,
                         hide_lemma=token_implies_code, hide_lemma=code_implies_accept,
                         hide_lemma=access_implies_issued,
                         hide_lemma=refresh_used_implies_issued]:
  exists-trace
  "∃ data ClientID nonce pkC code token iss #t1 #t2 #t3 #t4 #t5 #t6
     #t7 #t8 #t9 #t10.
    (((((((((((((((((((AS_Issued_Nonce( nonce ) @ #t1) ∧
                      (Client_Sent_Attestation_Request( ClientID, nonce, pkC ) @ #t2)) ∧
                     (AA_Signed_Attestation( nonce, pkC ) @ #t3)) ∧
                    (Backend_Issued_CAT( ClientID, pkC, nonce ) @ #t4)) ∧
                   (AS_Accepted_Client_Key( ClientID, pkC ) @ #t5)) ∧
                  (ROPCAuth_Initiated( ClientID ) @ #t6)) ∧
                 (AuthzCode_Issued( code, ClientID, pkC, iss ) @ #t7)) ∧
                (ROPC_Auth_Success( ClientID ) @ #t7)) ∧
               (Token_Issued( token, ClientID, pkC ) @ #t8)) ∧
              (Token_Used_For_Access( token, ClientID, pkC ) @ #t9)) ∧
             (Client_Recourse_Received( data, ClientID ) @ #t10)) ∧
            (#t1 < #t2)) ∧
           (#t2 < #t3)) ∧
          (#t3 < #t4)) ∧
         (#t4 < #t5)) ∧
        (#t5 < #t6)) ∧
       (#t6 < #t7)) ∧
      (#t7 < #t8)) ∧
     (#t8 < #t9)) ∧
    (#t9 < #t10)"
/*
guarded formula characterizing all satisfying traces:
"∃ data ClientID nonce pkC code token iss #t1 #t2 #t3 #t4 #t5 #t6
   #t7 #t8 #t9 #t10.
  (AS_Issued_Nonce( nonce ) @ #t1) ∧
  (Client_Sent_Attestation_Request( ClientID, nonce, pkC ) @ #t2) ∧
  (AA_Signed_Attestation( nonce, pkC ) @ #t3) ∧
  (Backend_Issued_CAT( ClientID, pkC, nonce ) @ #t4) ∧
  (AS_Accepted_Client_Key( ClientID, pkC ) @ #t5) ∧
  (ROPCAuth_Initiated( ClientID ) @ #t6) ∧
  (AuthzCode_Issued( code, ClientID, pkC, iss ) @ #t7) ∧
  (ROPC_Auth_Success( ClientID ) @ #t7) ∧
  (Token_Issued( token, ClientID, pkC ) @ #t8) ∧
  (Token_Used_For_Access( token, ClientID, pkC ) @ #t9) ∧
  (Client_Recourse_Received( data, ClientID ) @ #t10)
 ∧
  (#t1 < #t2) ∧
  (#t2 < #t3) ∧
  (#t3 < #t4) ∧
  (#t4 < #t5) ∧
  (#t5 < #t6) ∧
  (#t6 < #t7) ∧
  (#t7 < #t8) ∧
  (#t8 < #t9) ∧
  (#t9 < #t10)"
*/
simplify
solve( !AS_Identity( iss ) ▶₂ #t1 )
  case Setup_AS_Identity
  solve( Client_GenerateKey_ToClient_Step4( ClientID.1, ~nonce
         ) ▶₀ #t2 )
    case Client_GenerateKey_ToClient_Step4
    solve( !Client_Key( ClientID.1, skC, pk(x) ) ▶₁ #t2 )
      case Client_GenerateKey_ToClient_Step4
      solve( Client_KeygenSlot( ClientID.1 ) ▶₂ #t2 )
        case Client_AttestChallReq_ToBackend_Step2
        solve( Client_RequestAttestation_ToAA_Step5( <Device_Info.1, 
                                                      ~nonce, pk(~skC)>
               ) ▶₀ #t3 )
          case Client_RequestAttestation_ToAA_Step5
          solve( !AA_Ltk( aa_sk ) ▶₁ #t3 )
            case Setup_AA_Enclave
            solve( !Backend_Ltk( backend_sk ) ▶₁ #t4 )
              case Setup_Backend_Identity
              solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID.1, nonce.1,
                                                         iss.1
                     ) ▶₁ #t5 )
                case AS_IssueChallenge_ToBackend_Step3
                solve( !PkAA( ~ClientID.1, pk(x) ) ▶₂ #t5 )
                  case Setup_AA_Enclave
                  solve( !AS_Knows_Backend( pk(x) ) ▶₃ #t5 )
                    case Setup_Backend_Identity
                    solve( !AS_Identity( ~iss.1 ) ▶₄ #t5 )
                      case Setup_AS_Identity
                      solve( !Client_Expected_Iss( ~ClientID.1, iss.2 ) ▶₁ #t6 )
                        case Client_GenerateKey_ToClient_Step4
                        solve( !Client_Key( ~ClientID.1, skC.1, pkC ) ▶₂ #t6 )
                          case Client_GenerateKey_ToClient_Step4
                          solve( !UserPassword( password ) ▶₃ #t6 )
                            case Setup_User_Credentials
                            solve( !AS_StoredCredentials( password.1 ) ▶₁ #t7 )
                              case Setup_User_Credentials
                              solve( !AS_Client_Tied_PublicKey( ~ClientID.1, pk(~skC), iss.3
                                     ) ▶₂ #t7 )
                                case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                                solve( AuthzCode( authorization_code.1, ~ClientID.1, pk(~skC),
                                                  iss.4
                                       ) ▶₁ #t8 )
                                  case AS_VerifyROPC_SendCode_ROPCStep5_6
                                  solve( !AS_Client_Tied_PublicKey( ~ClientID.1, pk(~skC), ~iss.4
                                         ) ▶₂ #t8 )
                                    case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                                    solve( !AS_Identity( ~iss.4 ) ▶₆ #t8 )
                                      case Setup_AS_Identity
                                      solve( !ConstrainedAccess( ~constrained_access_token, pk(~skC)
                                             ) ▶₁ #t9 )
                                        case AS_TokenAns_ToBackend_Step13
                                        solve( !ConstrainedReference( DPoP_reference_token.1,
                                                                      pk(~skC), iss.5
                                               ) ▶₂ #t9 )
                                          case AS_TokenAns_ToBackend_Step13
                                          solve( !AS_Client_Tied_PublicKey( ~ClientID.1, pk(~skC),
                                                                            ~iss.5
                                                 ) ▶₃ #t9 )
                                            case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                                            solve( !AS_Identity( ~iss.5 ) ▶₄ #t9 )
                                              case Setup_AS_Identity
                                              solve( In_S( $RS, $Client,
                                                           <'resource_sent', data, ~ClientID.1>
                                                     ) ▶₀ #t10 )
                                                case ChanIn_S
                                                solve( In_S( $Backend, $AS, <'step2_b2as', ClientID>
                                                       ) ▶₀ #t1 )
                                                  case ChanIn_S
                                                  solve( In_S( $Client.1, $Backend.1,
                                                               <'wrap_cat_c2b', ~ClientID.1, 
                                                                ~nonce, pk(~skC), Device_Info.1, 
                                                                platformAttest>
                                                         ) ▶₀ #t4 )
                                                    case ChanIn_S
                                                    solve( In_S( $Backend.2, $AS.1,
                                                                 <'step9_b2as', ~ClientID.1, 
                                                                  ~nonce.2, Device_Info.2, 
                                                                  sign(<Device_Info.2, ~nonce.2, 
                                                                        pk(~skC)>,
                                                                       ~aa_sk.2), 
                                                                  sign(<'client-attestation+jwt', 
                                                                        ~ClientID.1, pk(~skC), 
                                                                        ~nonce.2, 
                                                                        sign(<Device_Info.2, 
                                                                              ~nonce.2, pk(~skC)>,
                                                                             ~aa_sk.2)
                                                                       >,
                                                                       ~backend_sk.1), 
                                                                  sign(<DPoP_Params, ~nonce.2>,
                                                                       ~skC), 
                                                                  pk(~skC), DPoP_Params, pk(~skC)>
                                                           ) ▶₀ #t5 )
                                                      case ChanIn_S
                                                      solve( In_S( $Backend.3, $Client.2,
                                                                   <'ropc_start_b2c', ~ClientID.1, 
                                                                    iss.2>
                                                             ) ▶₀ #t6 )
                                                        case ChanIn_S
                                                        solve( In_S( $Backend.4, $AS.2,
                                                                     <'ropc_auth_b2as', 
                                                                      sign(<DPoP_Params.1, 
                                                                            ~password.1>,
                                                                           ~skC), 
                                                                      pk(~skC), DPoP_Params.1, 
                                                                      ~password.1, ~ClientID.1>
                                                               ) ▶₀ #t7 )
                                                          case ChanIn_S
                                                          solve( In_S( $Backend.5, $AS.3,
                                                                       <'token_req_b2as', 
                                                                        ~ClientID.1, 
                                                                        ~authorization_code.1, 
                                                                        sign(<DPoP_Params_TE, 
                                                                              'token_endpoint'>,
                                                                             ~skC), 
                                                                        pk(~skC), DPoP_Params_TE>
                                                                 ) ▶₀ #t8 )
                                                            case ChanIn_S
                                                            solve( In_S( $RS.1, $AS.4,
                                                                         <'introspect', 
                                                                          ~constrained_access_token, 
                                                                          sign(<DPoP_Params2, 
                                                                                ~DPoP_reference_token.1
                                                                               >,
                                                                               ~skC), 
                                                                          pk(~skC), DPoP_Params2, 
                                                                          ~DPoP_reference_token.1, 
                                                                          ~ClientID.1>
                                                                   ) ▶₀ #t9 )
                                                              case ChanIn_S
                                                              solve( In_S( $Backend.6, $Client.3,
                                                                           <'step3_b2c', 
                                                                            ~ClientID.1, ~nonce, 
                                                                            iss.6>
                                                                     ) ▶₀ #vr.1 )
                                                                case ChanIn_S
                                                                solve( In_S( $Backend.7, $Client.4,
                                                                             <'step3_b2c', 
                                                                              ~ClientID.1, nonce.3, 
                                                                              iss.7>
                                                                       ) ▶₀ #vr.2 )
                                                                  case ChanIn_S
                                                                  solve( In_S( $Backend.9,
                                                                               $Client.6,
                                                                               <'step3_b2c', 
                                                                                ~ClientID.2, 
                                                                                nonce.4, iss.8>
                                                                         ) ▶₀ #vr.6 )
                                                                    case ChanIn_S
                                                                    solve( In_S( $Backend.10,
                                                                                 $Client.7,
                                                                                 <'step3_b2c', 
                                                                                  ~ClientID.2, 
                                                                                  nonce.5, iss.9>
                                                                           ) ▶₀ #vr.7 )
                                                                      case ChanIn_S
                                                                      solve( In_S( $Backend.12,
                                                                                   $AS.5,
                                                                                   <'step2_b2as', 
                                                                                    ~ClientID.1>
                                                                             ) ▶₀ #vr.10 )
                                                                        case ChanIn_S
                                                                        solve( In_S( $Backend.13,
                                                                                     $Client.9,
                                                                                     <'step3_b2c', 
                                                                                      ~ClientID.1, 
                                                                                      nonce.6, iss.2
                                                                                     >
                                                                               ) ▶₀ #vr.14 )
                                                                          case ChanIn_S
                                                                          solve( In_S( $Backend.14,
                                                                                       $Client.10,
                                                                                       <
                                                                                        'step3_b2c', 
                                                                                        ~ClientID.1, 
                                                                                        nonce.7, 
                                                                                        iss.10>
                                                                                 ) ▶₀ #vr.15 )
                                                                            case ChanIn_S
                                                                            solve( In_S( $Backend.15,
                                                                                         $AS.6,
                                                                                         <
                                                                                          'step9_b2as', 
                                                                                          ~ClientID.1, 
                                                                                          ~nonce.8, 
                                                                                          Device_Info.4, 
                                                                                          sign(<
                                                                                                Device_Info.4, 
                                                                                                ~nonce.8, 
                                                                                                pk(~skC)
                                                                                               >,
                                                                                               ~aa_sk.2), 
                                                                                          sign(<
                                                                                                'client-attestation+jwt', 
                                                                                                ~ClientID.1, 
                                                                                                pk(~skC), 
                                                                                                ~nonce.8, 
                                                                                                sign(<
                                                                                                      Device_Info.4, 
                                                                                                      ~nonce.8, 
                                                                                                      pk(~skC)
                                                                                                     >,
                                                                                                     ~aa_sk.2)
                                                                                               >,
                                                                                               ~backend_sk.2), 
