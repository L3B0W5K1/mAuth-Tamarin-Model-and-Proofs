lemma ROPC3_password_secrecy:
  all-traces
  "∀ pw #i.
    (Secret_UserPassword( pw ) @ #i) ⇒
    ((¬(∃ #j. K( pw ) @ #j)) ∨ (∃ #r. RevealPassword( pw ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ pw #i.
  (Secret_UserPassword( pw ) @ #i)
 ∧
  (∃ #j. (K( pw ) @ #j)) ∧ (∀ #r. (RevealPassword( pw ) @ #r) ⇒ ⊥)"
*/
simplify
solve( !KU( ~password ) @ #vk )
  case Reveal_User_Password
  by contradiction /* from formulas */
qed

lemma ROPC4_auth_requires_credentials:
  all-traces
  "∀ ClientID #i.
    (ROPC_Auth_Success( ClientID ) @ #i) ⇒
    ((∃ pw #j.
       (ROPC_Credentials_Used( ClientID, pw ) @ #j) ∧ (#j < #i)) ∨
     (∃ pw #r. RevealPassword( pw ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID #i.
  (ROPC_Auth_Success( ClientID ) @ #i)
 ∧
  (∀ pw #j.
    (ROPC_Credentials_Used( ClientID, pw ) @ #j) ⇒ ¬(#j < #i)) ∧
  (∀ pw #r. (RevealPassword( pw ) @ #r) ⇒ ⊥)"
*/
simplify
solve( (∃ nonce #j.1.
         (AA_Signed_Attestation( nonce, pk(x) ) @ #j.1) ∧ #j.1 < #j)  ∥
       (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
  case case_1
  solve( (∃ ClientID #j.2.
           (Client_Sent_Attestation_Request( ClientID, nonce.1, pk(x)
            ) @ #j.2)
          ∧
           #j.2 < #j.1)  ∥
         (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
    case case_1
    solve( !AS_StoredCredentials( password ) ▶₁ #i )
      case Setup_User_Credentials
      solve( !AS_Client_Tied_PublicKey( ClientID, pk(x), iss ) ▶₂ #i )
        case AS_VerifyJWTAndDPoPP_ToBackend_Step10
        solve( (∃ nonce #j.
                 (AA_Signed_Attestation( nonce, pk(x) ) @ #j) ∧ #j < #vr.1)  ∥
               (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
          case case_1
          solve( (∃ ClientID #j.4.
                   (Client_Sent_Attestation_Request( ClientID, nonce.4, pk(x)
                    ) @ #j.4)
                  ∧
                   #j.4 < #j.3)  ∥
                 (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
            case case_1
            solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce, iss.1
                   ) ▶₁ #j )
              case AS_IssueChallenge_ToBackend_Step3
              solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j )
                case Setup_AA_Enclave
                solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j )
                  case Setup_Backend_Identity
                  solve( !AS_Identity( ~iss.1 ) ▶₄ #j )
                    case Setup_AS_Identity
                    solve( Client_RequestAttestation_ToAA_Step5( <Device_Info.1, 
                                                                  nonce.1, pk(x)>
                           ) ▶₀ #j.1 )
                      case Client_RequestAttestation_ToAA_Step5
                      solve( !AA_Ltk( aa_sk.1 ) ▶₁ #j.1 )
                        case Setup_AA_Enclave
                        solve( Client_GenerateKey_ToClient_Step4( ClientID.1, nonce.1
                               ) ▶₀ #j.2 )
                          case Client_GenerateKey_ToClient_Step4
                          solve( !Client_Key( ClientID.1, skC.1, pk(~skC) ) ▶₁ #j.2 )
                            case Client_GenerateKey_ToClient_Step4
                            solve( Client_RequestAttestation_ToAA_Step5( <Device_Info.3, 
                                                                          nonce.3, pk(~skC)>
                                   ) ▶₀ #j.3 )
                              case Client_RequestAttestation_ToAA_Step5
                              solve( Client_GenerateKey_ToClient_Step4( ClientID.2, nonce.1
                                     ) ▶₀ #j.3 )
                                case Client_GenerateKey_ToClient_Step4
                                solve( !Client_Key( ClientID.2, skC.1, pk(~skC) ) ▶₁ #j.3 )
                                  case Client_GenerateKey_ToClient_Step4
                                  solve( In_S( $Backend, $AS,
                                               <'ropc_auth_b2as', 
                                                sign(<DPoP_Params, ~password>, ~skC), pk(~skC), 
                                                DPoP_Params, ~password, ~ClientID>
                                         ) ▶₀ #i )
                                    case ChanIn_S
                                    solve( In_S( $Backend.1, $AS.1,
                                                 <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                                                  sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk), 
                                                  sign(<'client-attestation+jwt', ~ClientID, 
                                                        pk(~skC), ~nonce, 
                                                        sign(<Device_Info, ~nonce, pk(~skC)>,
                                                             ~aa_sk)
                                                       >,
                                                       ~backend_sk), 
                                                  sign(<DPoP_Params.1, ~nonce>, ~skC), pk(~skC), 
                                                  DPoP_Params.1, pk(~skC)>
                                           ) ▶₀ #j )
                                      case ChanIn_S
                                      solve( In_S( $Backend.2, $AS.2,
                                                   <'step9_b2as', ~ClientID, ~nonce.2, 
                                                    Device_Info.2, 
                                                    sign(<Device_Info.2, ~nonce.2, pk(~skC)>,
                                                         ~aa_sk), 
                                                    sign(<'client-attestation+jwt', ~ClientID, 
                                                          pk(~skC), ~nonce.2, 
                                                          sign(<Device_Info.2, ~nonce.2, pk(~skC)>,
                                                               ~aa_sk)
                                                         >,
                                                         ~backend_sk.1), 
                                                    sign(<DPoP_Params.2, ~nonce.2>, ~skC), 
                                                    pk(~skC), DPoP_Params.2, pk(~skC)>
