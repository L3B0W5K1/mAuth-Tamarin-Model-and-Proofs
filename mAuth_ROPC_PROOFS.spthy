lemma I2_access_requires_hardware_key:
  all-traces
  "∀ token ClientID pkC #i #j.
    (((Token_Used_For_Access( token, ClientID, pkC ) @ #i) ∧
      (Token_Issued( token, ClientID, pkC ) @ #j)) ∧
     (#j < #i)) ⇒
    (((∃ #k #l.
        (((Client_Key_In_Hardware( pkC ) @ #k) ∧
          (AS_Accepted_Client_Key( ClientID, pkC ) @ #l)) ∧
         (#k < #l)) ∧
        (#l < #j)) ∨
      (∃ skC #r. RevealClientKey( ClientID, skC ) @ #r)) ∨
     (∃ aa_sk #r. RevealAA( aa_sk ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ token ClientID pkC #i #j.
  (Token_Used_For_Access( token, ClientID, pkC ) @ #i) ∧
  (Token_Issued( token, ClientID, pkC ) @ #j)
 ∧
  (#j < #i) ∧
  (∀ #k #l.
    (Client_Key_In_Hardware( pkC ) @ #k) ∧
    (AS_Accepted_Client_Key( ClientID, pkC ) @ #l)
   ⇒
    ((¬(#k < #l)) ∨ (¬(#l < #j)))) ∧
  (∀ skC #r. (RevealClientKey( ClientID, skC ) @ #r) ⇒ ⊥) ∧
  (∀ aa_sk #r. (RevealAA( aa_sk ) @ #r) ⇒ ⊥)"
*/
simplify
solve( (∃ #j.1 #k.
         (Client_Key_In_Hardware( pk(x) ) @ #j.1) ∧
         (AS_Accepted_Client_Key( ClientID, pk(x) ) @ #k)
        ∧
         (#j.1 < #k) ∧ (#k < #j))  ∥
       (∃ skC #r. (RevealClientKey( ClientID, skC ) @ #r))  ∥
       (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
  case case_1
  by contradiction /* from formulas */
next
  case case_2
  by contradiction /* from formulas */
next
  case case_3
  by contradiction /* from formulas */
qed

lemma E1_token_requires_authentication:
  all-traces
  "∀ token ClientID pkC #i.
    (Token_Issued( token, ClientID, pkC ) @ #i) ⇒
    (∃ #j. (AS_Auth_Completed( ClientID ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ token ClientID pkC #i.
  (Token_Issued( token, ClientID, pkC ) @ #i)
 ∧
  ∀ #j. (AS_Auth_Completed( ClientID ) @ #j) ⇒ ¬(#j < #i)"
*/
simplify
by contradiction /* from formulas */

lemma E2_resource_matches_issued_token:
  all-traces
  "∀ data ClientID #i.
    (Client_Recourse_Received( data, ClientID ) @ #i) ⇒
    (∃ token pkC #j #k.
      (((RS_Sent_Resource( data, ClientID, token ) @ #j) ∧
        (Token_Issued( token, ClientID, pkC ) @ #k)) ∧
       (#k < #j)) ∧
      (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ data ClientID #i.
  (Client_Recourse_Received( data, ClientID ) @ #i)
 ∧
  ∀ token pkC #j #k.
   (RS_Sent_Resource( data, ClientID, token ) @ #j) ∧
   (Token_Issued( token, ClientID, pkC ) @ #k)
  ⇒
   ((¬(#k < #j)) ∨ (¬(#j < #i)))"
*/
simplify
solve( In_S( $RS, $Client, <'resource_sent', data, ClientID>
       ) ▶₀ #i )
  case ChanIn_S
  solve( In_S( $AS, $RS,
               <'verified', ClientID, constrained_access_token>
         ) ▶₀ #vr.2 )
    case ChanIn_S
    by contradiction /* from formulas */
  qed
qed

