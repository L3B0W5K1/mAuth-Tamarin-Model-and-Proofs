lemma S3_reference_token_secrecy:
  all-traces
  "∀ token ClientID pkC #i.
    (RefToken_Issued( token, ClientID, pkC ) @ #i) ⇒
    ((¬(∃ #j. K( token ) @ #j)) ∨
     (∃ #l. LeakRefToken( token, pkC ) @ #l))"
/*
guarded formula characterizing all counter-examples:
"∃ token ClientID pkC #i.
  (RefToken_Issued( token, ClientID, pkC ) @ #i)
 ∧
  (∃ #j. (K( token ) @ #j)) ∧
  (∀ #l. (LeakRefToken( token, pkC ) @ #l) ⇒ ⊥)"
*/
simplify
solve( AuthzCode( authorization_code, ClientID, pk(x), iss
       ) ▶₁ #i )
  case AS_VerifyROPC_SendCode_ROPCStep5_6
  solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), ~iss ) ▶₂ #i )
    case AS_VerifyJWTAndDPoPP_ToBackend_Step10
    solve( !AS_Identity( ~iss ) ▶₆ #i )
      case Setup_AS_Identity
      solve( !AS_StoredCredentials( password.1 ) ▶₁ #j.1 )
        case Setup_User_Credentials
        solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), iss.1
               ) ▶₂ #j.1 )
          case AS_VerifyJWTAndDPoPP_ToBackend_Step10
          solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce, iss.2
                 ) ▶₁ #j.2 )
            case AS_IssueChallenge_ToBackend_Step3
            solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.2 )
              case Setup_AA_Enclave
              solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.2 )
                case Setup_Backend_Identity
                solve( !AS_Identity( ~iss.2 ) ▶₄ #j.2 )
                  case Setup_AS_Identity
                  solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.2,
                                                             iss.3
                         ) ▶₁ #j.3 )
                    case AS_IssueChallenge_ToBackend_Step3
                    solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.3 )
                      case Setup_AA_Enclave
                      solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.3 )
                        case Setup_Backend_Identity
                        solve( !AS_Identity( ~iss.3 ) ▶₄ #j.3 )
                          case Setup_AS_Identity
                          solve( In_S( $Backend, $AS,
                                       <'token_req_b2as', ~ClientID, ~authorization_code, 
                                        sign(<DPoP_Params_TE, 'token_endpoint'>, x), pk(x), 
                                        DPoP_Params_TE>
                                 ) ▶₀ #i )
                            case ChanIn_S
                            solve( In_S( $Backend.2, $AS.2,
                                         <'ropc_auth_b2as', sign(<DPoP_Params.1, ~password.1>, x), 
                                          pk(x), DPoP_Params.1, ~password.1, ~ClientID>
                                   ) ▶₀ #j.1 )
                              case ChanIn_S
                              solve( In_S( $Backend.3, $AS.3,
                                           <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                                            sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                                            sign(<'client-attestation+jwt', ~ClientID, pk(x), 
                                                  ~nonce, sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)
                                                 >,
                                                 ~backend_sk), 
                                            sign(<DPoP_Params.2, ~nonce>, x), pk(x), DPoP_Params.2, 
                                            pk(x)>
                                     ) ▶₀ #j.2 )
                                case ChanIn_S
                                solve( In_S( $Backend.1, $AS.1,
                                             <'ropc_auth_b2as', sign(<DPoP_Params, ~password>, x), 
                                              pk(x), DPoP_Params, ~password, ~ClientID>
                                       ) ▶₀ #vr )
                                  case ChanIn_S
                                  solve( In_S( $Backend.4, $AS.4,
                                               <'step9_b2as', ~ClientID, ~nonce.1, Device_Info.1, 
                                                sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk), 
                                                sign(<'client-attestation+jwt', ~ClientID, pk(x), 
                                                      ~nonce.1, 
                                                      sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk)
                                                     >,
                                                     ~backend_sk.1), 
                                                sign(<DPoP_Params.3, ~nonce.1>, x), pk(x), 
                                                DPoP_Params.3, pk(x)>
                                         ) ▶₀ #vr.2 )
                                    case ChanIn_S
                                    solve( In_S( $Backend.6, $AS.6, <'step2_b2as', ~ClientID>
                                           ) ▶₀ #vr.3 )
                                      case ChanIn_S
                                      solve( In_S( $Backend.7, $Client,
                                                   <'step3_b2c', ~ClientID, nonce.3, iss.4>
                                             ) ▶₀ #vr.8 )
                                        case ChanIn_S
                                        solve( In_S( $Backend.5, $AS.5,
                                                     <'step9_b2as', ~ClientID, ~nonce.2, 
                                                      Device_Info.2, 
                                                      sign(<Device_Info.2, ~nonce.2, pk(x)>,
                                                           ~aa_sk), 
                                                      sign(<'client-attestation+jwt', ~ClientID, 
                                                            pk(x), ~nonce.2, 
                                                            sign(<Device_Info.2, ~nonce.2, pk(x)>,
                                                                 ~aa_sk)
                                                           >,
                                                           ~backend_sk.2), 
                                                      sign(<DPoP_Params.4, ~nonce.2>, x), pk(x), 
                                                      DPoP_Params.4, pk(x)>
                                               ) ▶₀ #j.3 )
                                          case ChanIn_S
                                          solve( In_S( $Backend.9, $AS.7,
                                                       <'step9_b2as', ~ClientID, ~nonce.4, 
                                                        Device_Info.4, 
                                                        sign(<Device_Info.4, ~nonce.4, pk(x)>,
                                                             ~aa_sk), 
                                                        sign(<'client-attestation+jwt', ~ClientID, 
                                                              pk(x), ~nonce.4, 
                                                              sign(<Device_Info.4, ~nonce.4, pk(x)>,
                                                                   ~aa_sk)
                                                             >,
                                                             ~backend_sk.3), 
                                                        sign(<DPoP_Params.5, ~nonce.4>, x), pk(x), 
                                                        DPoP_Params.5, pk(x)>
                                                 ) ▶₀ #vr.10 )
                                            case ChanIn_S
                                            solve( In_S( $Backend.10, $AS.8,
                                                         <'step2_b2as', ~ClientID>
                                                   ) ▶₀ #vr.11 )
                                              case ChanIn_S
                                              solve( In_S( $Backend.11, $AS.9,
                                                           <'step9_b2as', ~ClientID, ~nonce.5, 
                                                            Device_Info.5, 
                                                            sign(<Device_Info.5, ~nonce.5, pk(x)>,
                                                                 ~aa_sk), 
                                                            sign(<'client-attestation+jwt', 
                                                                  ~ClientID, pk(x), ~nonce.5, 
                                                                  sign(<Device_Info.5, ~nonce.5, 
                                                                        pk(x)>,
                                                                       ~aa_sk)
                                                                 >,
                                                                 ~backend_sk.4), 
                                                            sign(<DPoP_Params.6, ~nonce.5>, x), 
                                                            pk(x), DPoP_Params.6, pk(x)>
                                                     ) ▶₀ #vr.14 )
                                                case ChanIn_S
                                                solve( In_S( $Backend.12, $AS.10,
                                                             <'step2_b2as', ~ClientID>
                                                       ) ▶₀ #vr.15 )
                                                  case ChanIn_S
                                                  solve( In_S( $Backend.13, $AS.11,
                                                               <'step2_b2as', ~ClientID>
                                                         ) ▶₀ #vr.18 )
                                                    case ChanIn_S
                                                    solve( In_S( $Backend.14, $AS.12,
                                                                 <'step2_b2as', ~ClientID>
                                                           ) ▶₀ #vr.21 )
                                                      case ChanIn_S
                                                      solve( In_S( $Client.2, $Backend,
                                                                   <'dpop_for_token_c2b', 
                                                                    sign(<DPoP_Params_TE, 
                                                                          'token_endpoint'>,
                                                                         x), 
                                                                    pk(x), DPoP_Params_TE, ~ClientID
                                                                   >
                                                             ) ▶₀ #vr.26 )
                                                        case ChanIn_S
                                                        solve( In_S( $AS.13, $Backend.15,
                                                                     <'auth_completed_as2b', 
                                                                      ~ClientID, ~authorization_code
                                                                     >
                                                               ) ▶₀ #vr.27 )
                                                          case ChanIn_S
                                                          solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID,
                                                                                                     nonce.6,
                                                                                                     iss.5
                                                                 ) ▶₁ #j.4 )
                                                            case AS_IssueChallenge_ToBackend_Step3
                                                            solve( !PkAA( ~ClientID, pk(x)
                                                                   ) ▶₂ #j.4 )
                                                              case Setup_AA_Enclave
                                                              solve( !AS_Knows_Backend( pk(x)
                                                                     ) ▶₃ #j.4 )
                                                                case Setup_Backend_Identity
                                                                solve( !AS_Identity( ~iss.4
                                                                       ) ▶₄ #j.4 )
                                                                  case Setup_AS_Identity
                                                                  solve( In_S( $Client.4,
                                                                               $Backend.2,
                                                                               <'ropc_auth_c2b', 
                                                                                sign(<
                                                                                      DPoP_Params.1, 
                                                                                      ~password.1>,
                                                                                     ~skC), 
                                                                                pk(~skC), 
                                                                                DPoP_Params.1, 
                                                                                ~password.1, 
                                                                                ~ClientID>
                                                                         ) ▶₀ #vr.30 )
                                                                    case ChanIn_S
                                                                    solve( In_S( $Client.5,
                                                                                 $Backend.3,
                                                                                 <'step9_c2b', 
                                                                                  ~ClientID, 
                                                                                  ~nonce, 
                                                                                  Device_Info, 
                                                                                  sign(<
                                                                                        Device_Info, 
                                                                                        ~nonce, 
                                                                                        pk(~skC)>,
                                                                                       ~aa_sk), 
                                                                                  sign(<
                                                                                        'client-attestation+jwt', 
                                                                                        ~ClientID, 
                                                                                        pk(~skC), 
                                                                                        ~nonce, 
                                                                                        sign(<
                                                                                              Device_Info, 
                                                                                              ~nonce, 
                                                                                              pk(~skC)
                                                                                             >,
                                                                                             ~aa_sk)
                                                                                       >,
                                                                                       ~backend_sk), 
                                                                                  sign(<
                                                                                        DPoP_Params.1, 
                                                                                        ~nonce>,
                                                                                       ~skC), 
                                                                                  pk(~skC), 
                                                                                  DPoP_Params.1, 
                                                                                  pk(~skC)>
                                                                           ) ▶₀ #vr.33 )
                                                                      case ChanIn_S
                                                                      solve( In_S( $Client.6,
                                                                                   $Backend.1,
                                                                                   <
                                                                                    'ropc_auth_c2b', 
                                                                                    sign(<
                                                                                          DPoP_Params, 
                                                                                          ~password
                                                                                         >,
                                                                                         ~skC), 
                                                                                    pk(~skC), 
                                                                                    DPoP_Params, 
                                                                                    ~password, 
                                                                                    ~ClientID>
                                                                             ) ▶₀ #vr.36 )
                                                                        case ChanIn_S
                                                                        solve( In_S( $Client.7,
                                                                                     $Backend.4,
                                                                                     <'step9_c2b', 
                                                                                      ~ClientID, 
                                                                                      ~nonce.1, 
                                                                                      Device_Info.1, 
                                                                                      sign(<
                                                                                            Device_Info.1, 
                                                                                            ~nonce.1, 
                                                                                            pk(~skC)
                                                                                           >,
                                                                                           ~aa_sk), 
                                                                                      sign(<
                                                                                            'client-attestation+jwt', 
