   ⇒
    ¬(#k < #j))"
*/
simplify
solve( AuthzCode( authorization_code, ClientID, pk(x), iss_orig
       ) ▶₁ #i )
  case AS_VerifyROPC_SendCode_ROPCStep5_6
  by contradiction /* from formulas */
qed

