lemma SANITY_resource_received [hide_lemma=R2_dpop_requires_creation,
                                hide_lemma=B1_attestation_unforgeable,
                                hide_lemma=B2_as_requires_attestation,
                                hide_lemma=B3_token_implies_attestation,
                                hide_lemma=accept_implies_hardware,
                                hide_lemma=I1_token_requires_hardware_key,
                                hide_lemma=accept_unique_pkC, hide_lemma=client_iss_unique,
                                hide_lemma=token_implies_code, hide_lemma=code_implies_accept,
                                hide_lemma=access_implies_issued,
                                hide_lemma=refresh_used_implies_issued]:
  exists-trace
  "∃ data cid #t. Client_Recourse_Received( data, cid ) @ #t"
/*
guarded formula characterizing all satisfying traces:
"∃ data cid #t. (Client_Recourse_Received( data, cid ) @ #t)"
*/
simplify
solve( In_S( $RS, $Client, <'resource_sent', data, cid> ) ▶₀ #t )
  case ChanIn_S
  solve( In_S( $AS, $RS, <'verified', cid, constrained_access_token>
         ) ▶₀ #vr.2 )
    case ChanIn_S
    solve( In_S( $Backend, $RS.1,
                 <'rs_verify_b2rs', ~constrained_access_token, dpopp, pkC, 
                  DPoP_Params2, DPoP_reference_token, ~ClientID>
           ) ▶₀ #vr.4 )
      case ChanIn_S
      solve( In_S( $RS, $AS,
                   <'introspect', ~constrained_access_token, 
                    sign(<DPoP_Params2.1, ~DPoP_reference_token.2>, x), pk(x), 
                    DPoP_Params2.1, ~DPoP_reference_token.2, ~ClientID>
             ) ▶₀ #vr.7 )
        case ChanIn_S
        solve( In_S( $Backend.1, $AS.2,
                     <'token_req_b2as', ~ClientID.1, ~authorization_code, 
                      sign(<DPoP_Params_TE, 'token_endpoint'>, x), pk(x), DPoP_Params_TE>
               ) ▶₀ #vr.8 )
          case ChanIn_S
          solve( In_S( $Backend.2, $AS.3,
                       <'token_req_b2as', ~ClientID.2, ~authorization_code.1, 
                        sign(<DPoP_Params_TE.1, 'token_endpoint'>, x), pk(x), 
                        DPoP_Params_TE.1>
                 ) ▶₀ #vr.9 )
            case ChanIn_S
            solve( In_S( $Backend.3, $AS.4,
                         <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                          sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                          sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                               ~backend_sk), 
                          sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, pk(x)>
                   ) ▶₀ #vr.10 )
              case ChanIn_S
              solve( In_S( $Backend.4, $AS.5,
                           <'ropc_auth_b2as', sign(<DPoP_Params.1, ~password>, x), pk(x), 
                            DPoP_Params.1, ~password, ~ClientID.1>
                     ) ▶₀ #vr.12 )
                case ChanIn_S
                solve( In_S( $Backend.5, $AS.6,
                             <'step9_b2as', ~ClientID.1, ~nonce.1, Device_Info.1, 
                              sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk.1), 
                              sign(<'client-attestation+jwt', ~ClientID.1, pk(x), ~nonce.1, 
                                    sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk.1)>,
                                   ~backend_sk.1), 
                              sign(<DPoP_Params.2, ~nonce.1>, x), pk(x), DPoP_Params.2, pk(x)>
                       ) ▶₀ #vr.13 )
                  case ChanIn_S
                  solve( In_S( $Backend.6, $AS.7,
                               <'ropc_auth_b2as', sign(<DPoP_Params.3, ~password.1>, x), pk(x), 
                                DPoP_Params.3, ~password.1, ~ClientID.2>
                         ) ▶₀ #vr.15 )
                    case ChanIn_S
                    solve( In_S( $Backend.7, $AS.8,
                                 <'step9_b2as', ~ClientID.2, ~nonce.2, Device_Info.2, 
                                  sign(<Device_Info.2, ~nonce.2, pk(x)>, ~aa_sk.2), 
                                  sign(<'client-attestation+jwt', ~ClientID.2, pk(x), ~nonce.2, 
                                        sign(<Device_Info.2, ~nonce.2, pk(x)>, ~aa_sk.2)>,
                                       ~backend_sk.2), 
                                  sign(<DPoP_Params.4, ~nonce.2>, x), pk(x), DPoP_Params.4, pk(x)>
                           ) ▶₀ #vr.16 )
                      case ChanIn_S
                      solve( In_S( $Backend.8, $AS.9, <'step2_b2as', ~ClientID>
                             ) ▶₀ #vr.17 )
                        case ChanIn_S
                        solve( In_S( $Backend.9, $AS.10,
                                     <'step9_b2as', ~ClientID.1, ~nonce.3, Device_Info.3, 
                                      sign(<Device_Info.3, ~nonce.3, pk(x)>, ~aa_sk.1), 
                                      sign(<'client-attestation+jwt', ~ClientID.1, pk(x), ~nonce.3, 
                                            sign(<Device_Info.3, ~nonce.3, pk(x)>, ~aa_sk.1)>,
                                           ~backend_sk.3), 
                                      sign(<DPoP_Params.5, ~nonce.3>, x), pk(x), DPoP_Params.5, 
                                      pk(x)>
