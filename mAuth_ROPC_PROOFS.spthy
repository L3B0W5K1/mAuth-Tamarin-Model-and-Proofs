                                             <'step3_as2b', ~ClientID.1, nonce.1, iss.1>
                                       ) ▶₀ #vr.21 )
                                  case ChanIn_S
                                  solve( In_S( $Backend.4, $Client.5,
                                               <'cat_response_b2c', ~ClientID, 
                                                sign(<'client-attestation+jwt', ~ClientID, 
                                                      pk(~skC), ~nonce, 
                                                      sign(<~Device_Info, ~nonce, pk(~skC)>, ~aa_sk)
                                                     >,
                                                     ~backend_sk), 
                                                sign(<~Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>
                                         ) ▶₀ #vr.25 )
                                    case ChanIn_S
                                    by contradiction /* from formulas */
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      next
                        case case_2
                        solve( In_S( $Client.5, $Backend.1, <'step2_c2b', ~ClientID>
                               ) ▶₀ #vr.16 )
                          case ChanIn_S
                          solve( In_S( $AS.2, $Backend.2,
                                       <'step3_as2b', ~ClientID, ~nonce, iss.1>
                                 ) ▶₀ #vr.19 )
                            case ChanIn_S
                            solve( In_S( $AS.2, $Backend.2,
                                         <'step3_as2b', ~ClientID.1, nonce.1, iss.1>
                                   ) ▶₀ #vr.22 )
                              case ChanIn_S
                              solve( In_S( $Backend.4, $Client.5,
                                           <'cat_response_b2c', ~ClientID, 
                                            sign(<'client-attestation+jwt', ~ClientID, pk(~skC), 
                                                  ~nonce, 
                                                  sign(<~Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>,
                                                 ~backend_sk), 
                                            sign(<~Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>
                                     ) ▶₀ #vr.26 )
                                case ChanIn_S
                                by contradiction /* from formulas */
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma B7_dpop_jkt_matches_instance_key:
  all-traces
  "∀ ClientID pkC #i.
    (AS_Verified_dpop_jkt( ClientID, pkC ) @ #i) ⇒
    ((∃ nonce #j.
       (Client_Sent_Attestation_Request( ClientID, nonce, pkC ) @ #j) ∧
       (#j < #i)) ∨
     (∃ skC #r. RevealClientKey( ClientID, skC ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID pkC #i.
  (AS_Verified_dpop_jkt( ClientID, pkC ) @ #i)
 ∧
  (∀ nonce #j.
    (Client_Sent_Attestation_Request( ClientID, nonce, pkC ) @ #j)
   ⇒
    ¬(#j < #i)) ∧
  (∀ skC #r. (RevealClientKey( ClientID, skC ) @ #r) ⇒ ⊥)"
*/
simplify
solve( (∃ nonce #j.
         (AA_Signed_Attestation( nonce, pk(x) ) @ #j) ∧ #j < #i)  ∥
       (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
  case case_1
  solve( (∃ ClientID #j.1.
           (Client_Sent_Attestation_Request( ClientID, nonce.1, pk(x)
            ) @ #j.1)
          ∧
           #j.1 < #j)  ∥
         (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
    case case_1
    solve( AS_Pending_Challenge_Nonce_Useable( ClientID, nonce, iss
           ) ▶₁ #i )
      case AS_IssueChallenge_ToBackend_Step3
      solve( !PkAA( ClientID, pk(x.1) ) ▶₂ #i )
        case Setup_AA_Enclave
        solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #i )
          case Setup_Backend_Identity
          solve( !AS_Identity( ~iss ) ▶₄ #i )
            case Setup_AS_Identity
            solve( Client_RequestAttestation_ToAA_Step5( <Device_Info.1, 
                                                          nonce.1, pk(x)>
                   ) ▶₀ #j )
              case Client_RequestAttestation_ToAA_Step5
              solve( !AA_Ltk( aa_sk.1 ) ▶₁ #j )
                case Setup_AA_Enclave
                solve( Client_GenerateKey_ToClient_Step4( ClientID.1, nonce.1
                       ) ▶₀ #j.1 )
                  case Client_GenerateKey_ToClient_Step4
                  solve( !Client_Key( ClientID.1, skC.1, pk(~skC) ) ▶₁ #j.1 )
                    case Client_GenerateKey_ToClient_Step4
                    solve( In_S( $Backend, $AS,
                                 <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                                  sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk), 
                                  sign(<'client-attestation+jwt', ~ClientID, pk(~skC), ~nonce, 
                                        sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>,
                                       ~backend_sk), 
                                  sign(<DPoP_Params, ~nonce>, ~skC), pk(~skC), DPoP_Params, pk(~skC)
                                 >
                           ) ▶₀ #i )
                      case ChanIn_S
                      solve( In_S( $Backend.1, $AS.1, <'step2_b2as', ~ClientID>
                             ) ▶₀ #vr )
                        case ChanIn_S
                        solve( In_S( $Backend.2, $Client,
                                     <'step3_b2c', ~ClientID, nonce.2, iss.1>
                               ) ▶₀ #vr.4 )
                          case ChanIn_S
                          solve( In_S( $Backend.4, $Client.2,
                                       <'step3_b2c', ~ClientID.1, nonce.1, iss.2>
                                 ) ▶₀ #vr.7 )
                            case ChanIn_S
                            solve( In_S( $Backend.6, $Client.4,
                                         <'step3_b2c', ~ClientID.2, nonce.3, iss.3>
                                   ) ▶₀ #vr.11 )
                              case ChanIn_S
                              solve( In_S( $Client.6, $Backend,
                                           <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                            sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk), 
                                            sign(<'client-attestation+jwt', ~ClientID, pk(~skC), 
                                                  ~nonce, 
                                                  sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>,
                                                 ~backend_sk), 
                                            sign(<DPoP_Params, ~nonce>, ~skC), pk(~skC), 
                                            DPoP_Params, pk(~skC)>
                                     ) ▶₀ #vr.15 )
                                case ChanIn_S
                                by contradiction /* from formulas */
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  next
    case case_2
    solve( AS_Pending_Challenge_Nonce_Useable( ClientID, nonce, iss
           ) ▶₁ #i )
      case AS_IssueChallenge_ToBackend_Step3
      solve( !PkAA( ClientID, pk(x.1) ) ▶₂ #i )
        case Setup_AA_Enclave
        solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #i )
          case Setup_Backend_Identity
          solve( !AS_Identity( ~iss ) ▶₄ #i )
            case Setup_AS_Identity
            solve( Client_RequestAttestation_ToAA_Step5( <Device_Info.1, 
                                                          nonce.1, pk(x)>
                   ) ▶₀ #j )
              case Client_RequestAttestation_ToAA_Step5
              solve( !AA_Ltk( aa_sk.1 ) ▶₁ #j )
                case Setup_AA_Enclave
                solve( !AA_Ltk( aa_sk.2 ) ▶₀ #r )
                  case Setup_AA_Enclave
                  solve( In_S( $Backend, $AS,
                               <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                                sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk), 
                                sign(<'client-attestation+jwt', ~ClientID, pk(~skC), ~nonce, 
                                      sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>,
                                     ~backend_sk), 
                                sign(<DPoP_Params, ~nonce>, ~skC), pk(~skC), DPoP_Params, pk(~skC)>
                         ) ▶₀ #i )
                    case ChanIn_S
                    solve( In_S( $Backend.1, $AS.1, <'step2_b2as', ~ClientID>
                           ) ▶₀ #vr )
                      case ChanIn_S
                      solve( In_S( $Backend.2, $Client,
                                   <'step3_b2c', ~ClientID, nonce.2, iss.1>
                             ) ▶₀ #vr.4 )
                        case ChanIn_S
                        solve( In_S( $Backend.4, $Client.2,
                                     <'step3_b2c', ~ClientID.1, nonce.1, iss.2>
                               ) ▶₀ #vr.8 )
                          case ChanIn_S
                          solve( In_S( $Backend.6, $Client.4,
                                       <'step3_b2c', ~ClientID.2, nonce.3, iss.3>
                                 ) ▶₀ #vr.12 )
                            case ChanIn_S
                            solve( In_S( $Backend.8, $Client.6,
                                         <'step3_b2c', ~ClientID.3, nonce.4, iss.4>
                                   ) ▶₀ #vr.16 )
                              case ChanIn_S
                              solve( In_S( $Client.8, $Backend,
                                           <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                            sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk), 
                                            sign(<'client-attestation+jwt', ~ClientID, pk(~skC), 
                                                  ~nonce, 
                                                  sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>,
                                                 ~backend_sk), 
                                            sign(<DPoP_Params, ~nonce>, ~skC), pk(~skC), 
                                            DPoP_Params, pk(~skC)>
                                     ) ▶₀ #vr.20 )
                                case ChanIn_S
                                by contradiction /* from formulas */
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
next
  case case_2
  solve( AS_Pending_Challenge_Nonce_Useable( ClientID, nonce, iss
         ) ▶₁ #i )
    case AS_IssueChallenge_ToBackend_Step3
    solve( !PkAA( ClientID, pk(x.1) ) ▶₂ #i )
      case Setup_AA_Enclave
      solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #i )
        case Setup_Backend_Identity
        solve( !AS_Identity( ~iss ) ▶₄ #i )
          case Setup_AS_Identity
          solve( !AA_Ltk( aa_sk.1 ) ▶₀ #r )
            case Setup_AA_Enclave
            solve( In_S( $Backend, $AS,
                         <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                          sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                          sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                               ~backend_sk), 
                          sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, pk(x)>
                   ) ▶₀ #i )
              case ChanIn_S
              solve( In_S( $Backend.1, $AS.1, <'step2_b2as', ~ClientID>
                     ) ▶₀ #vr )
                case ChanIn_S
                solve( In_S( $Backend.2, $Client,
                             <'step3_b2c', ~ClientID, nonce.1, iss.1>
                       ) ▶₀ #vr.4 )
                  case ChanIn_S
                  solve( In_S( $Backend.4, $Client.2,
                               <'step3_b2c', ~ClientID.1, nonce.2, iss.2>
                         ) ▶₀ #vr.9 )
                    case ChanIn_S
                    solve( In_S( $Client.4, $Backend,
                                 <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                  sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                                  sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                        sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                       ~backend_sk), 
                                  sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, pk(x)>
                           ) ▶₀ #vr.13 )
                      case ChanIn_S
                      by contradiction /* from formulas */
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma K1_key_continuity_attestation_to_token:
  all-traces
  "∀ ClientID pkC_accept token pkC_token #i #j.
    (((AS_Accepted_Client_Key( ClientID, pkC_accept ) @ #i) ∧
      (Token_Issued( token, ClientID, pkC_token ) @ #j)) ∧
     (#i < #j)) ⇒
    ((pkC_accept = pkC_token) ∨
     (∃ skC #r. RevealClientKey( ClientID, skC ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID pkC_accept token pkC_token #i #j.
  (AS_Accepted_Client_Key( ClientID, pkC_accept ) @ #i) ∧
  (Token_Issued( token, ClientID, pkC_token ) @ #j)
 ∧
  (#i < #j) ∧
  (¬(pkC_accept = pkC_token)) ∧
  (∀ skC #r. (RevealClientKey( ClientID, skC ) @ #r) ⇒ ⊥)"
*/
simplify
by contradiction /* from formulas */

lemma K2_key_continuity_token_to_access:
  all-traces
  "∀ token ClientID pkC1 pkC2 #i #j.
    ((Token_Issued( token, ClientID, pkC1 ) @ #i) ∧
     (Token_Used_For_Access( token, ClientID, pkC2 ) @ #j)) ⇒
    (pkC1 = pkC2)"
/*
guarded formula characterizing all counter-examples:
"∃ token ClientID pkC1 pkC2 #i #j.
  (Token_Issued( token, ClientID, pkC1 ) @ #i) ∧
  (Token_Used_For_Access( token, ClientID, pkC2 ) @ #j)
 ∧
  ¬(pkC1 = pkC2)"
*/
simplify
by contradiction /* from formulas */

lemma K3_dpop_key_matches_accepted:
  all-traces
  "∀ params pkC_dpop ClientID pkC_accept token #i #j #k.
    (((((DPoP_Verified( params, pkC_dpop ) @ #i) ∧
        (AS_Accepted_Client_Key( ClientID, pkC_accept ) @ #j)) ∧
       (Token_Used_For_Access( token, ClientID, pkC_dpop ) @ #k)) ∧
      (#j < #i)) ∧
     (#i = #k)) ⇒
    ((pkC_dpop = pkC_accept) ∨
     (∃ skC #r. RevealClientKey( ClientID, skC ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ params pkC_dpop ClientID pkC_accept token #i #j #k.
  (DPoP_Verified( params, pkC_dpop ) @ #i) ∧
  (AS_Accepted_Client_Key( ClientID, pkC_accept ) @ #j) ∧
  (Token_Used_For_Access( token, ClientID, pkC_dpop ) @ #k) ∧
  (#i = #k)
 ∧
  (#j < #i) ∧
  (¬(pkC_dpop = pkC_accept)) ∧
  (∀ skC #r. (RevealClientKey( ClientID, skC ) @ #r) ⇒ ⊥)"
*/
simplify
by contradiction /* from formulas */

lemma I1_token_requires_hardware_key [reuse]:
  all-traces
  "∀ token ClientID pkC #i.
    (Token_Issued( token, ClientID, pkC ) @ #i) ⇒
    (((∃ #j #k.
        (((Client_Key_In_Hardware( pkC ) @ #j) ∧
          (AS_Accepted_Client_Key( ClientID, pkC ) @ #k)) ∧
         (#j < #k)) ∧
        (#k < #i)) ∨
      (∃ skC #r. RevealClientKey( ClientID, skC ) @ #r)) ∨
     (∃ aa_sk #r. RevealAA( aa_sk ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ token ClientID pkC #i.
  (Token_Issued( token, ClientID, pkC ) @ #i)
 ∧
  (∀ #j #k.
    (Client_Key_In_Hardware( pkC ) @ #j) ∧
    (AS_Accepted_Client_Key( ClientID, pkC ) @ #k)
   ⇒
    ((¬(#j < #k)) ∨ (¬(#k < #i)))) ∧
  (∀ skC #r. (RevealClientKey( ClientID, skC ) @ #r) ⇒ ⊥) ∧
  (∀ aa_sk #r. (RevealAA( aa_sk ) @ #r) ⇒ ⊥)"
*/
simplify
solve( (∃ nonce #j #k.
         (AA_Signed_Attestation( nonce, pk(x) ) @ #j) ∧
         (AS_Accepted_Client_Key( ClientID, pk(x) ) @ #k)
        ∧
         (#j < #k) ∧ (#k < #i))  ∥
       (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
  case case_1
  solve( (∃ nonce #j.2.
           (AA_Signed_Attestation( nonce, pk(x) ) @ #j.2) ∧ #j.2 < #j.1)  ∥
         (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
    case case_1
    solve( (∃ nonce #j.4.
             (AA_Signed_Attestation( nonce, pk(x) ) @ #j.4) ∧ #j.4 < #j.3)  ∥
           (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
      case case_1
      solve( (∃ nonce #j.
               (AA_Signed_Attestation( nonce, pk(x) ) @ #j) ∧ #j < #k)  ∥
             (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
        case case_1
        solve( (∃ ClientID #j.5.
                 (Client_Sent_Attestation_Request( ClientID, nonce.3, pk(x)
                  ) @ #j.5)
                ∧
                 #j.5 < #j.4)  ∥
               (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
          case case_1
          solve( (∃ ClientID #j.6.
                   (Client_Sent_Attestation_Request( ClientID, nonce.4, pk(x)
                    ) @ #j.6)
                  ∧
                   #j.6 < #j.5)  ∥
                 (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
            case case_1
            solve( (∃ ClientID #j.7.
                     (Client_Sent_Attestation_Request( ClientID, nonce.5, pk(x)
                      ) @ #j.7)
                    ∧
                     #j.7 < #j.6)  ∥
                   (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
              case case_1
              solve( (∃ ClientID #j.8.
                       (Client_Sent_Attestation_Request( ClientID, nonce.6, pk(x)
                        ) @ #j.8)
                      ∧
                       #j.8 < #j.7)  ∥
                     (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                case case_1
                solve( AuthzCode( authorization_code, ClientID, pk(x), iss
                       ) ▶₁ #i )
                  case AS_VerifyROPC_SendCode_ROPCStep5_6
                  solve( (∃ nonce #j.
                           (AA_Signed_Attestation( nonce, pk(x) ) @ #j) ∧ #j < #vr.2)  ∥
                         (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                    case case_1
                    solve( (∃ nonce #j.13.
                             (AA_Signed_Attestation( nonce, pk(x) ) @ #j.13) ∧ #j.13 < #j.12)  ∥
                           (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                      case case_1
                      solve( (∃ ClientID #j.14.
                               (Client_Sent_Attestation_Request( ClientID, nonce.10, pk(x)
                                ) @ #j.14)
                              ∧
                               #j.14 < #j.13)  ∥
                             (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                        case case_1
                        solve( (∃ ClientID #j.15.
                                 (Client_Sent_Attestation_Request( ClientID, nonce.11, pk(x)
                                  ) @ #j.15)
                                ∧
                                 #j.15 < #j.14)  ∥
                               (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                          case case_1
                          solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), ~iss ) ▶₂ #i )
                            case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                            solve( (∃ nonce #j.
                                     (AA_Signed_Attestation( nonce, pk(x) ) @ #j) ∧ #j < #vr.10)  ∥
                                   (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                              case case_1
                              solve( (∃ ClientID #j.18.
                                       (Client_Sent_Attestation_Request( ClientID, nonce.13, pk(x)
                                        ) @ #j.18)
                                      ∧
                                       #j.18 < #j.17)  ∥
                                     (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                                case case_1
                                solve( !AS_Identity( ~iss ) ▶₆ #i )
                                  case Setup_AS_Identity
                                  solve( !AS_StoredCredentials( password ) ▶₁ #j )
                                    case Setup_User_Credentials
                                    solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), iss.1
                                           ) ▶₂ #j )
                                      case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                                      solve( (∃ nonce #j.
                                               (AA_Signed_Attestation( nonce, pk(x) ) @ #j)
                                              ∧
                                               #j < #vr.14)  ∥
                                             (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                                        case case_1
                                        solve( (∃ ClientID #j.20.
                                                 (Client_Sent_Attestation_Request( ClientID,
                                                                                   nonce.15, pk(x)
                                                  ) @ #j.20)
                                                ∧
                                                 #j.20 < #j.19)  ∥
                                               (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
                                          case case_1
                                          solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID,
                                                                                     nonce.1, iss.3
                                                 ) ▶₁ #j.1 )
                                            case AS_IssueChallenge_ToBackend_Step3
                                            solve( !PkAA( ~ClientID, pk(x.3) ) ▶₂ #j.1 )
                                              case Setup_AA_Enclave
                                              solve( !AS_Knows_Backend( pk(x.3) ) ▶₃ #j.1 )
                                                case Setup_Backend_Identity
                                                solve( !AS_Identity( ~iss.3 ) ▶₄ #j.1 )
                                                  case Setup_AS_Identity
                                                  solve( !AS_StoredCredentials( password.2
                                                         ) ▶₁ #j.2 )
                                                    case Setup_User_Credentials
                                                    solve( !AS_Client_Tied_PublicKey( ~ClientID,
                                                                                      pk(x), iss.4
                                                           ) ▶₂ #j.2 )
                                                      case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                                                      solve( (∃ nonce #j.
                                                               (AA_Signed_Attestation( nonce, pk(x)
                                                                ) @ #j)
                                                              ∧
                                                               #j < #vr.22)  ∥
                                                             (∃ aa_sk #r.
                                                               (RevealAA( aa_sk ) @ #r)) )
                                                        case case_1
                                                        solve( (∃ ClientID #j.22.
                                                                 (Client_Sent_Attestation_Request( ClientID,
                                                                                                   nonce.17,
                                                                                                   pk(x)
                                                                  ) @ #j.22)
                                                                ∧
