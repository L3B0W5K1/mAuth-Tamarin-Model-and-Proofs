rule (modulo E) AS_VerifyROPC_SendCode_ROPCStep5_6[role=AS]:
   [
   In_S( $Backend, $AS,
         <'ropc_auth_b2as', dpopp, pkC, DPoP_Params, password, ClientID>
   ),
   !AS_StoredCredentials( password ),
   !AS_Client_Tied_PublicKey( ClientID, pkC, iss ),
   Fr( ~authorization_code )
   ]
  --[
  Eq( verify(dpopp, <DPoP_Params, password>, pkC), true ),
  DPoP_Used( DPoP_Params ), DPoP_Verified( DPoP_Params, pkC ),
  ROPC_Auth_Success( ClientID ),
  AS_Request_Accepted( <'ropc_auth', DPoP_Params> ),
  AS_Auth_Completed( ClientID ),
  AuthzCode_Issued( ~authorization_code, ClientID, pkC, iss )
  ]->
   [
   Out_S( $AS, $Backend,
          <'auth_completed_as2b', ClientID, ~authorization_code>
   ),
   AuthzCode( ~authorization_code, ClientID, pkC, iss )
   ]

