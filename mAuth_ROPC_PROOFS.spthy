                                       hide_lemma=B2_as_requires_attestation,
                                       hide_lemma=B3_token_implies_attestation,
                                       hide_lemma=accept_implies_hardware,
                                       hide_lemma=I1_token_requires_hardware_key]:
  all-traces
  "∀ data ClientID #i.
    (Client_Recourse_Received( data, ClientID ) @ #i) ⇒
    ((∃ pkC ctx params #j #k.
       ((((Client_Created_DPoP( pkC, params, ctx ) @ #j) ∧
          (DPoP_Verified( params, pkC ) @ #k)) ∧
         (#j < #k)) ∧
        (#k < #i)) ∧
       (∃ #l. AS_Accepted_Client_Key( ClientID, pkC ) @ #l)) ∨
     (∃ skC #r. RevealClientKey( ClientID, skC ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ data ClientID #i.
  (Client_Recourse_Received( data, ClientID ) @ #i)
 ∧
