lemma B1_attestation_unforgeable [reuse]:
  all-traces
  "∀ nonce pkC #i.
    (AA_Signed_Attestation( nonce, pkC ) @ #i) ⇒
    ((∃ ClientID #j.
       (Client_Sent_Attestation_Request( ClientID, nonce, pkC ) @ #j) ∧
       (#j < #i)) ∨
     (∃ aa_sk #r. RevealAA( aa_sk ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ nonce pkC #i.
  (AA_Signed_Attestation( nonce, pkC ) @ #i)
 ∧
  (∀ ClientID #j.
    (Client_Sent_Attestation_Request( ClientID, nonce, pkC ) @ #j)
   ⇒
    ¬(#j < #i)) ∧
  (∀ aa_sk #r. (RevealAA( aa_sk ) @ #r) ⇒ ⊥)"
*/
simplify
solve( Client_RequestAttestation_ToAA_Step5( <Device_Info, nonce, 
                                              pkC>
       ) ▶₀ #i )
  case Client_RequestAttestation_ToAA_Step5
  by contradiction /* from formulas */
qed

lemma B2_as_requires_attestation [reuse]:
  all-traces
  "∀ ClientID pkC #i.
    (AS_Accepted_Client_Key( ClientID, pkC ) @ #i) ⇒
    ((∃ nonce #j.
       (AA_Signed_Attestation( nonce, pkC ) @ #j) ∧ (#j < #i)) ∨
     (∃ aa_sk #r. RevealAA( aa_sk ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID pkC #i.
  (AS_Accepted_Client_Key( ClientID, pkC ) @ #i)
 ∧
  (∀ nonce #j.
    (AA_Signed_Attestation( nonce, pkC ) @ #j) ⇒ ¬(#j < #i)) ∧
  (∀ aa_sk #r. (RevealAA( aa_sk ) @ #r) ⇒ ⊥)"
*/
simplify
solve( AS_Pending_Challenge_Nonce_Useable( ClientID, nonce, iss
       ) ▶₁ #i )
  case AS_IssueChallenge_ToBackend_Step3
  solve( !PkAA( ClientID, pk(x.1) ) ▶₂ #i )
    case Setup_AA_Enclave
    solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #i )
      case Setup_Backend_Identity
      solve( !AS_Identity( ~iss ) ▶₄ #i )
        case Setup_AS_Identity
        solve( In_S( $Backend, $AS,
                     <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                      sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                      sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                            sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                           ~backend_sk), 
                      sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, pk(x)>
               ) ▶₀ #i )
          case ChanIn_S
          solve( In_S( $Backend.1, $AS.1, <'step2_b2as', ~ClientID>
                 ) ▶₀ #vr )
            case ChanIn_S
            solve( In_S( $Backend.2, $Client,
                         <'step3_b2c', ~ClientID, nonce.1, iss.1>
                   ) ▶₀ #vr.4 )
              case ChanIn_S
              solve( In_S( $Client.2, $Backend,
                           <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                            sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                            sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                  sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                 ~backend_sk), 
                            sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, pk(x)>
                     ) ▶₀ #vr.9 )
                case ChanIn_S
                by contradiction /* from formulas */
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma B3_token_implies_attestation [reuse]:
  all-traces
  "∀ token ClientID pkC #i.
    (Token_Issued( token, ClientID, pkC ) @ #i) ⇒
    ((∃ nonce #j #k.
       (((AA_Signed_Attestation( nonce, pkC ) @ #j) ∧
         (AS_Accepted_Client_Key( ClientID, pkC ) @ #k)) ∧
        (#j < #k)) ∧
       (#k < #i)) ∨
     (∃ aa_sk #r. RevealAA( aa_sk ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ token ClientID pkC #i.
  (Token_Issued( token, ClientID, pkC ) @ #i)
 ∧
  (∀ nonce #j #k.
    (AA_Signed_Attestation( nonce, pkC ) @ #j) ∧
    (AS_Accepted_Client_Key( ClientID, pkC ) @ #k)
   ⇒
    ((¬(#j < #k)) ∨ (¬(#k < #i)))) ∧
  (∀ aa_sk #r. (RevealAA( aa_sk ) @ #r) ⇒ ⊥)"
*/
simplify
solve( (∃ nonce #j.2.
         (AA_Signed_Attestation( nonce, pk(x) ) @ #j.2) ∧ #j.2 < #j.1)  ∥
       (∃ aa_sk #r. (RevealAA( aa_sk ) @ #r)) )
  case case_1
  by contradiction /* from formulas */
next
  case case_2
  by contradiction /* from formulas */
qed

lemma B4_attestation_key_binding:
  all-traces
  "∀ ClientID1 ClientID2 pkC1 pkC2 nonce #i #j #k1 #k2.
    ((((AS_Accepted_Client_Key( ClientID1, pkC1 ) @ #i) ∧
       (AS_Accepted_Client_Key( ClientID2, pkC2 ) @ #j)) ∧
      (AA_Signed_Attestation( nonce, pkC1 ) @ #k1)) ∧
     (AA_Signed_Attestation( nonce, pkC2 ) @ #k2)) ⇒
    (pkC1 = pkC2)"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID1 ClientID2 pkC1 pkC2 nonce #i #j #k1 #k2.
  (AS_Accepted_Client_Key( ClientID1, pkC1 ) @ #i) ∧
  (AS_Accepted_Client_Key( ClientID2, pkC2 ) @ #j) ∧
  (AA_Signed_Attestation( nonce, pkC1 ) @ #k1) ∧
  (AA_Signed_Attestation( nonce, pkC2 ) @ #k2)
 ∧
  ¬(pkC1 = pkC2)"
*/
simplify
by contradiction /* from formulas */

lemma B5_attestation_nonce_single_use:
  all-traces
  "∀ nonce #i #j.
    ((AA_NonceUsed( nonce ) @ #i) ∧ (AA_NonceUsed( nonce ) @ #j)) ⇒
    (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ nonce #i #j.
  (AA_NonceUsed( nonce ) @ #i) ∧ (AA_NonceUsed( nonce ) @ #j)
 ∧
  ¬(#i = #j)"
*/
simplify
by contradiction /* from formulas */

