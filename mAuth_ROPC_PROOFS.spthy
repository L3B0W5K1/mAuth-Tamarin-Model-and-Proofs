                                                sign(<'client-attestation+jwt', ~ClientID, pk(x), 
                                                      ~nonce.1, 
                                                      sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk)
                                                     >,
                                                     ~backend_sk.1), 
                                                sign(<DPoP_Params.3, ~nonce.1>, x), pk(x), 
                                                DPoP_Params.3, pk(x)>
                                         ) ▶₀ #vr.2 )
                                    case ChanIn_S
                                    solve( In_S( $Backend.6, $AS.6, <'step2_b2as', ~ClientID>
                                           ) ▶₀ #vr.3 )
                                      case ChanIn_S
