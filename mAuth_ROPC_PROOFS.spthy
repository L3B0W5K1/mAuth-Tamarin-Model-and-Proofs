                      case Setup_AS_Identity
                      solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.1,
                                                                 iss.4
                             ) ▶₁ #j.3 )
                        case AS_IssueChallenge_ToBackend_Step3
                        solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.3 )
                          case Setup_AA_Enclave
                          solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.3 )
                            case Setup_Backend_Identity
                            solve( !AS_Identity( ~iss.4 ) ▶₄ #j.3 )
                              case Setup_AS_Identity
                              solve( !AS_StoredCredentials( password.1 ) ▶₁ #j.4 )
                                case Setup_User_Credentials
                                solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), iss.6
                                       ) ▶₂ #j.4 )
                                  case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                                  solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.2,
                                                                             iss.7
                                         ) ▶₁ #j.5 )
                                    case AS_IssueChallenge_ToBackend_Step3
                                    solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.5 )
                                      case Setup_AA_Enclave
                                      solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.5 )
                                        case Setup_Backend_Identity
                                        solve( !AS_Identity( ~iss.7 ) ▶₄ #j.5 )
                                          case Setup_AS_Identity
                                          solve( In_S( $Backend.1, $AS.1,
                                                       <'token_req_b2as', ~ClientID, 
                                                        ~authorization_code, 
                                                        sign(<DPoP_Params_TE, 'token_endpoint'>,
                                                             x), 
                                                        pk(x), DPoP_Params_TE>
                                                 ) ▶₀ #j )
                                            case ChanIn_S
                                            solve( In_S( $Backend.2, $AS.2,
                                                         <'ropc_auth_b2as', 
                                                          sign(<DPoP_Params, ~password>, x), pk(x), 
                                                          DPoP_Params, ~password, ~ClientID>
                                                   ) ▶₀ #j.1 )
                                              case ChanIn_S
                                              solve( In_S( $Backend.3, $AS.3,
                                                           <'step9_b2as', ~ClientID, ~nonce, 
                                                            Device_Info, 
                                                            sign(<Device_Info, ~nonce, pk(x)>,
                                                                 ~aa_sk), 
                                                            sign(<'client-attestation+jwt', 
                                                                  ~ClientID, pk(x), ~nonce, 
                                                                  sign(<Device_Info, ~nonce, pk(x)>,
                                                                       ~aa_sk)
                                                                 >,
                                                                 ~backend_sk), 
                                                            sign(<DPoP_Params.1, ~nonce>, x), 
                                                            pk(x), DPoP_Params.1, pk(x)>
                                                     ) ▶₀ #j.2 )
                                                case ChanIn_S
                                                solve( In_S( $Client, $Backend,
                                                             <'refresh_req_c2b', 
                                                              sign(<params, 'refresh'>, x), pk(x), 
                                                              params, ~ClientID>
                                                       ) ▶₀ #vr.2 )
                                                  case ChanIn_S
                                                  by contradiction /* from formulas */
                                                qed
                                              qed
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
