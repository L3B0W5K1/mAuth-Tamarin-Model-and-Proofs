  AS_Accepted_Client_Key( ClientID, pkC ),
  AS_Verified_CAT( ClientID, pkC ),
  AS_Verified_PlatformAttest( ClientID, pkC ),
  AS_Verified_dpop_jkt( ClientID, pkC ), DPoP_Used( DPoP_Params ),
  DPoP_Verified( DPoP_Params, pkC )
  ]->
   [
   Out_S( $AS, $Backend, <'ropc_start_as2b', ClientID, iss> ),
   !AS_Client_Tied_PublicKey( ClientID, pkC, iss )
   ]

