/*
guarded formula characterizing all satisfying traces:
"∃ t cid pk #i. (RefreshToken_Used( t, cid, pk ) @ #i)"
*/
simplify
solve( In_S( $Backend, $AS,
             <'refresh_req_b2as', t, sign(<DPoP_Params_R, 'refresh'>, x), 
              pk(x), DPoP_Params_R, cid>
       ) ▶₀ #i )
