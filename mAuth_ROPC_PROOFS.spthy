lemma refresh_used_implies_issued [reuse]:
  all-traces
  "∀ t cid pk #i.
    (RefreshToken_Used( t, cid, pk ) @ #i) ⇒
    (∃ #j. (RefreshToken_Issued( t, cid, pk ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ t cid pk #i.
  (RefreshToken_Used( t, cid, pk ) @ #i)
 ∧
  ∀ #j. (RefreshToken_Issued( t, cid, pk ) @ #j) ⇒ ¬(#j < #i)"
*/
simplify
solve( In_S( $Backend, $AS,
             <'refresh_req_b2as', t, sign(<DPoP_Params_R, 'refresh'>, x), 
              pk(x), DPoP_Params_R, cid>
       ) ▶₀ #i )
  case ChanIn_S
  solve( !ConstrainedRefresh( t, pk(x) ) ▶₁ #i )
    case AS_TokenAns_ToBackend_Step13
    solve( !AS_Client_Tied_PublicKey( cid, pk(x), iss ) ▶₂ #i )
      case AS_VerifyJWTAndDPoPP_ToBackend_Step10
      solve( !AS_Identity( ~iss ) ▶₃ #i )
        case Setup_AS_Identity
        solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID.1, nonce,
                                                   iss.1
               ) ▶₁ #j )
          case AS_IssueChallenge_ToBackend_Step3
          solve( !PkAA( ~ClientID.1, pk(x.1) ) ▶₂ #j )
            case Setup_AA_Enclave
            solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j )
              case Setup_Backend_Identity
              solve( !AS_Identity( ~iss.1 ) ▶₄ #j )
                case Setup_AS_Identity
                solve( !AS_StoredCredentials( password ) ▶₁ #j.1 )
                  case Setup_User_Credentials
                  solve( !AS_Client_Tied_PublicKey( ~ClientID.1, pk(x), iss.2
                         ) ▶₂ #j.1 )
                    case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                    solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID.1, nonce.1,
                                                               iss.3
                           ) ▶₁ #j.2 )
                      case AS_IssueChallenge_ToBackend_Step3
                      solve( !PkAA( ~ClientID.1, pk(x.1) ) ▶₂ #j.2 )
                        case Setup_AA_Enclave
                        solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.2 )
                          case Setup_Backend_Identity
                          solve( !AS_Identity( ~iss.3 ) ▶₄ #j.2 )
                            case Setup_AS_Identity
                            solve( In_S( $Client, $Backend,
                                         <'refresh_req_c2b', sign(<DPoP_Params_R, 'refresh'>, x), 
                                          pk(x), DPoP_Params_R, ~ClientID>
                                   ) ▶₀ #vr.2 )
                              case ChanIn_S
                              solve( In_S( $AS.4, $Backend.4,
                                           <'token_resp_as2b', ~ClientID, DPoP_reference_token.1, 
                                            constrained_access_token.1, pk(~skC), iss.4, 
                                            ~refresh_token>
                                     ) ▶₀ #vr.3 )
                                case ChanIn_S
                                by contradiction /* from formulas */
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma accept_unique_pkC [reuse, use_induction]:
  all-traces
  "∀ cid pk1 pk2 #i #j.
    ((AS_Accepted_Client_Key( cid, pk1 ) @ #i) ∧
     (AS_Accepted_Client_Key( cid, pk2 ) @ #j)) ⇒
    (pk1 = pk2)"
/*
guarded formula characterizing all counter-examples:
"∃ cid pk1 pk2 #i #j.
  (AS_Accepted_Client_Key( cid, pk1 ) @ #i) ∧
  (AS_Accepted_Client_Key( cid, pk2 ) @ #j)
 ∧
  ¬(pk1 = pk2)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( (last(#j))  ∥ (last(#i))  ∥ (pk(x) = pk(x.3)) )
    case case_1
    solve( AS_Pending_Challenge_Nonce_Useable( cid, nonce, iss
           ) ▶₁ #i )
      case AS_IssueChallenge_ToBackend_Step3
      solve( !PkAA( cid, pk(x.1) ) ▶₂ #i )
        case Setup_AA_Enclave
        solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #i )
          case Setup_Backend_Identity
          solve( !AS_Identity( ~iss ) ▶₄ #i )
            case Setup_AS_Identity
            solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.1,
                                                       iss.1
                   ) ▶₁ #j )
              case AS_IssueChallenge_ToBackend_Step3
              solve( !PkAA( ~ClientID, pk(x.2) ) ▶₂ #j )
                case Setup_AA_Enclave
                solve( !AS_Knows_Backend( pk(x.2) ) ▶₃ #j )
                  case Setup_Backend_Identity
                  solve( !AS_Identity( ~iss.1 ) ▶₄ #j )
                    case Setup_AS_Identity
                    solve( In_S( $Backend, $AS,
                                 <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                                  sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                                  sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                        sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                       ~backend_sk), 
                                  sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, pk(x)>
                           ) ▶₀ #i )
                      case ChanIn_S
                      solve( In_S( $Backend.1, $AS.1,
                                   <'step9_b2as', ~ClientID, ~nonce.1, Device_Info.1, 
                                    sign(<Device_Info.1, ~nonce.1, pk(x.1)>, ~aa_sk), 
                                    sign(<'client-attestation+jwt', ~ClientID, pk(x.1), ~nonce.1, 
                                          sign(<Device_Info.1, ~nonce.1, pk(x.1)>, ~aa_sk)>,
                                         ~backend_sk.1), 
                                    sign(<DPoP_Params.1, ~nonce.1>, x.1), pk(x.1), DPoP_Params.1, 
                                    pk(x.1)>
                             ) ▶₀ #j )
                        case ChanIn_S
                        solve( In_S( $Backend.2, $AS.2, <'step2_b2as', ~ClientID>
                               ) ▶₀ #vr )
                          case ChanIn_S
                          solve( In_S( $Backend.3, $Client,
                                       <'step3_b2c', ~ClientID, nonce.2, iss.2>
                                 ) ▶₀ #vr.4 )
                            case ChanIn_S
                            solve( In_S( $Backend.4, $Client.1,
                                         <'step3_b2c', ~ClientID, nonce.3, iss.3>
                                   ) ▶₀ #vr.5 )
                              case ChanIn_S
                              solve( In_S( $Backend.6, $AS.3, <'step2_b2as', ~ClientID>
                                     ) ▶₀ #vr.8 )
                                case ChanIn_S
                                solve( In_S( $Client.3, $Backend,
                                             <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                              sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                                              sign(<'client-attestation+jwt', ~ClientID, pk(x), 
                                                    ~nonce, 
                                                    sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                                   ~backend_sk), 
                                              sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, 
                                              pk(x)>
                                       ) ▶₀ #vr.13 )
                                  case ChanIn_S
                                  solve( In_S( $Client.4, $Backend.1,
                                               <'step9_c2b', ~ClientID, ~nonce.1, Device_Info.1, 
                                                sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk), 
                                                sign(<'client-attestation+jwt', ~ClientID, pk(x), 
                                                      ~nonce.1, 
                                                      sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk)
                                                     >,
                                                     ~backend_sk.1), 
                                                sign(<DPoP_Params.1, ~nonce.1>, x), pk(x), 
                                                DPoP_Params.1, pk(x)>
                                         ) ▶₀ #vr.16 )
                                    case ChanIn_S
                                    by contradiction /* from formulas */
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  next
    case case_2
    solve( AS_Pending_Challenge_Nonce_Useable( cid, nonce, iss
           ) ▶₁ #i )
      case AS_IssueChallenge_ToBackend_Step3
      solve( !PkAA( cid, pk(x.1) ) ▶₂ #i )
        case Setup_AA_Enclave
        solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #i )
          case Setup_Backend_Identity
          solve( !AS_Identity( ~iss ) ▶₄ #i )
            case Setup_AS_Identity
            solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.1,
                                                       iss.1
                   ) ▶₁ #j )
              case AS_IssueChallenge_ToBackend_Step3
              solve( !PkAA( ~ClientID, pk(x.2) ) ▶₂ #j )
                case Setup_AA_Enclave
                solve( !AS_Knows_Backend( pk(x.2) ) ▶₃ #j )
                  case Setup_Backend_Identity
                  solve( !AS_Identity( ~iss.1 ) ▶₄ #j )
                    case Setup_AS_Identity
                    solve( In_S( $Backend, $AS,
                                 <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                                  sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                                  sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                        sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                       ~backend_sk), 
                                  sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, pk(x)>
                           ) ▶₀ #i )
                      case ChanIn_S
                      solve( In_S( $Backend.1, $AS.1,
                                   <'step9_b2as', ~ClientID, ~nonce.1, Device_Info.1, 
                                    sign(<Device_Info.1, ~nonce.1, pk(x.1)>, ~aa_sk), 
                                    sign(<'client-attestation+jwt', ~ClientID, pk(x.1), ~nonce.1, 
                                          sign(<Device_Info.1, ~nonce.1, pk(x.1)>, ~aa_sk)>,
                                         ~backend_sk.1), 
                                    sign(<DPoP_Params.1, ~nonce.1>, x.1), pk(x.1), DPoP_Params.1, 
                                    pk(x.1)>
                             ) ▶₀ #j )
                        case ChanIn_S
                        solve( In_S( $Backend.2, $AS.2, <'step2_b2as', ~ClientID>
                               ) ▶₀ #vr )
                          case ChanIn_S
                          solve( In_S( $Backend.3, $Client,
                                       <'step3_b2c', ~ClientID, nonce.2, iss.2>
                                 ) ▶₀ #vr.4 )
                            case ChanIn_S
                            solve( In_S( $Backend.4, $Client.1,
                                         <'step3_b2c', ~ClientID, nonce.3, iss.3>
                                   ) ▶₀ #vr.5 )
                              case ChanIn_S
                              solve( In_S( $Backend.6, $AS.3, <'step2_b2as', ~ClientID>
                                     ) ▶₀ #vr.8 )
                                case ChanIn_S
                                solve( In_S( $Client.3, $Backend,
                                             <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                              sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                                              sign(<'client-attestation+jwt', ~ClientID, pk(x), 
                                                    ~nonce, 
                                                    sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                                   ~backend_sk), 
                                              sign(<DPoP_Params, ~nonce>, x), pk(x), DPoP_Params, 
                                              pk(x)>
                                       ) ▶₀ #vr.13 )
                                  case ChanIn_S
                                  solve( In_S( $Client.4, $Backend.1,
                                               <'step9_c2b', ~ClientID, ~nonce.1, Device_Info.1, 
                                                sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk), 
                                                sign(<'client-attestation+jwt', ~ClientID, pk(x), 
                                                      ~nonce.1, 
                                                      sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk)
                                                     >,
                                                     ~backend_sk.1), 
                                                sign(<DPoP_Params.1, ~nonce.1>, x), pk(x), 
                                                DPoP_Params.1, pk(x)>
                                         ) ▶₀ #vr.16 )
                                    case ChanIn_S
                                    by contradiction /* from formulas */
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

lemma client_iss_unique [reuse, use_induction]:
  all-traces
  "∀ cid iss1 iss2 #i #j.
    ((Client_Learned_Iss( cid, iss1 ) @ #i) ∧
     (Client_Learned_Iss( cid, iss2 ) @ #j)) ⇒
    ((iss1 = iss2) ∧ (#i = #j))"
/*
guarded formula characterizing all counter-examples:
"∃ cid iss1 iss2 #i #j.
  (Client_Learned_Iss( cid, iss1 ) @ #i) ∧
  (Client_Learned_Iss( cid, iss2 ) @ #j)
 ∧
  ((¬(iss1 = iss2)) ∨ (¬(#i = #j)))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( (¬(iss1 = iss2))  ∥ (¬(#i = #j)) )
    case case_1
    solve( (last(#j))  ∥ (last(#i))  ∥ ((iss1 = iss2) ∧ (#i = #j)) )
      case case_1
      solve( In_S( $Backend, $Client, <'step3_b2c', cid, nonce, iss1>
             ) ▶₀ #i )
        case ChanIn_S
        solve( In_S( $Backend.1, $Client.1,
                     <'step3_b2c', cid, nonce.1, iss2>
               ) ▶₀ #j )
          case ChanIn_S
          solve( In_S( $AS, $Backend, <'step3_as2b', cid, nonce, iss1>
                 ) ▶₀ #vr.2 )
            case ChanIn_S
            solve( In_S( $AS.1, $Backend.1, <'step3_as2b', cid, nonce.1, iss2>
                   ) ▶₀ #vr.5 )
              case ChanIn_S
              solve( In_S( $Backend, $AS, <'step2_b2as', cid> ) ▶₀ #vr.8 )
                case ChanIn_S
                solve( In_S( $Backend.1, $AS.1, <'step2_b2as', cid> ) ▶₀ #vr.12 )
                  case ChanIn_S
                  solve( In_S( $Client.2, $Backend, <'step2_c2b', cid> ) ▶₀ #vr.16 )
                    case ChanIn_S
                    solve( In_S( $Client.3, $Backend.1, <'step2_c2b', ~ClientID>
                           ) ▶₀ #vr.19 )
                      case ChanIn_S
                      by contradiction /* from formulas */
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    next
      case case_2
      solve( In_S( $Backend, $Client, <'step3_b2c', cid, nonce, iss1>
             ) ▶₀ #i )
        case ChanIn_S
        solve( In_S( $Backend.1, $Client.1,
                     <'step3_b2c', cid, nonce.1, iss2>
               ) ▶₀ #j )
          case ChanIn_S
          solve( In_S( $AS, $Backend, <'step3_as2b', cid, nonce, iss1>
                 ) ▶₀ #vr.2 )
            case ChanIn_S
            solve( In_S( $AS.1, $Backend.1, <'step3_as2b', cid, nonce.1, iss2>
                   ) ▶₀ #vr.5 )
              case ChanIn_S
              solve( In_S( $Backend, $AS, <'step2_b2as', cid> ) ▶₀ #vr.8 )
                case ChanIn_S
                solve( In_S( $Backend.1, $AS.1, <'step2_b2as', cid> ) ▶₀ #vr.12 )
                  case ChanIn_S
                  solve( In_S( $Client.2, $Backend, <'step2_c2b', cid> ) ▶₀ #vr.16 )
                    case ChanIn_S
                    solve( In_S( $Client.3, $Backend.1, <'step2_c2b', ~ClientID>
                           ) ▶₀ #vr.19 )
                      case ChanIn_S
                      by contradiction /* from formulas */
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    next
      case case_3
      by contradiction /* from formulas */
    qed
  next
    case case_2
    solve( (last(#j))  ∥ (last(#i))  ∥ ((iss1 = iss2) ∧ (#i = #j)) )
      case case_1
      solve( In_S( $Backend, $Client, <'step3_b2c', cid, nonce, iss1>
             ) ▶₀ #i )
        case ChanIn_S
        solve( In_S( $Backend.1, $Client.1,
                     <'step3_b2c', cid, nonce.1, iss2>
               ) ▶₀ #j )
          case ChanIn_S
          solve( In_S( $AS, $Backend, <'step3_as2b', cid, nonce, iss1>
                 ) ▶₀ #vr.2 )
            case ChanIn_S
            solve( In_S( $AS.1, $Backend.1, <'step3_as2b', cid, nonce.1, iss2>
                   ) ▶₀ #vr.5 )
              case ChanIn_S
              solve( In_S( $Backend, $AS, <'step2_b2as', cid> ) ▶₀ #vr.8 )
                case ChanIn_S
                solve( In_S( $Backend.1, $AS.1, <'step2_b2as', cid> ) ▶₀ #vr.12 )
                  case ChanIn_S
                  solve( In_S( $Client.2, $Backend, <'step2_c2b', cid> ) ▶₀ #vr.16 )
                    case ChanIn_S
                    solve( In_S( $Client.3, $Backend.1, <'step2_c2b', ~ClientID>
                           ) ▶₀ #vr.19 )
                      case ChanIn_S
                      by contradiction /* cyclic */
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    next
      case case_2
      solve( In_S( $Backend, $Client, <'step3_b2c', cid, nonce, iss1>
             ) ▶₀ #i )
        case ChanIn_S
        solve( In_S( $Backend.1, $Client.1,
                     <'step3_b2c', cid, nonce.1, iss2>
               ) ▶₀ #j )
          case ChanIn_S
          solve( In_S( $AS, $Backend, <'step3_as2b', cid, nonce, iss1>
                 ) ▶₀ #vr.2 )
            case ChanIn_S
            solve( In_S( $AS.1, $Backend.1, <'step3_as2b', cid, nonce.1, iss2>
                   ) ▶₀ #vr.5 )
              case ChanIn_S
              solve( In_S( $Backend, $AS, <'step2_b2as', cid> ) ▶₀ #vr.8 )
                case ChanIn_S
                solve( In_S( $Backend.1, $AS.1, <'step2_b2as', cid> ) ▶₀ #vr.12 )
                  case ChanIn_S
                  solve( In_S( $Client.2, $Backend, <'step2_c2b', cid> ) ▶₀ #vr.16 )
                    case ChanIn_S
                    solve( In_S( $Client.3, $Backend.1, <'step2_c2b', ~ClientID>
                           ) ▶₀ #vr.19 )
                      case ChanIn_S
                      by contradiction /* cyclic */
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    next
      case case_3
      by contradiction /* from formulas */
    qed
  qed
qed

lemma L_unique_dpopp_proof:
  all-traces
  "∀ params #i #j.
    ((DPoP_Used( params ) @ #i) ∧ (DPoP_Used( params ) @ #j)) ⇒
    (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ params #i #j.
  (DPoP_Used( params ) @ #i) ∧ (DPoP_Used( params ) @ #j)
 ∧
  ¬(#i = #j)"
*/
simplify
by contradiction /* from formulas */

lemma L_unique_attestation_proof:
  all-traces
  "∀ nonce pkC1 pkC2 #i #j.
    ((AA_Signed_Attestation( nonce, pkC1 ) @ #i) ∧
     (AA_Signed_Attestation( nonce, pkC2 ) @ #j)) ⇒
    ((#i = #j) ∧ (pkC1 = pkC2))"
/*
guarded formula characterizing all counter-examples:
"∃ nonce pkC1 pkC2 #i #j.
  (AA_Signed_Attestation( nonce, pkC1 ) @ #i) ∧
  (AA_Signed_Attestation( nonce, pkC2 ) @ #j)
 ∧
  ((¬(#i = #j)) ∨ (¬(pkC1 = pkC2)))"
*/
simplify
by contradiction /* from formulas */

lemma SANITY_keygen [hide_lemma=R2_dpop_requires_creation,
                     hide_lemma=B1_attestation_unforgeable,
                     hide_lemma=B2_as_requires_attestation,
                     hide_lemma=B3_token_implies_attestation,
                     hide_lemma=accept_implies_hardware,
                     hide_lemma=I1_token_requires_hardware_key,
                     hide_lemma=accept_unique_pkC, hide_lemma=client_iss_unique,
                     hide_lemma=token_implies_code, hide_lemma=code_implies_accept,
                     hide_lemma=access_implies_issued,
                     hide_lemma=refresh_used_implies_issued]:
  exists-trace "∃ cid pk #t. Client_Learned_Iss( cid, pk ) @ #t"
/*
guarded formula characterizing all satisfying traces:
"∃ cid pk #t. (Client_Learned_Iss( cid, pk ) @ #t)"
*/
simplify
solve( In_S( $Backend, $Client, <'step3_b2c', cid, nonce, pk>
       ) ▶₀ #t )
  case ChanIn_S
  solve( In_S( $AS, $Backend, <'step3_as2b', cid, nonce, pk>
         ) ▶₀ #vr.2 )
    case ChanIn_S
    solve( In_S( $Backend, $AS, <'step2_b2as', cid> ) ▶₀ #vr.5 )
      case ChanIn_S
      solve( In_S( $Client.1, $Backend, <'step2_c2b', cid> ) ▶₀ #vr.9 )
        case ChanIn_S
        SOLVED // trace found
      qed
    qed
  qed
qed

lemma SANITY_token_issued [hide_lemma=R2_dpop_requires_creation,
                           hide_lemma=B1_attestation_unforgeable,
                           hide_lemma=B2_as_requires_attestation,
                           hide_lemma=B3_token_implies_attestation,
                           hide_lemma=accept_implies_hardware,
                           hide_lemma=I1_token_requires_hardware_key,
                           hide_lemma=accept_unique_pkC, hide_lemma=client_iss_unique,
                           hide_lemma=token_implies_code, hide_lemma=code_implies_accept,
                           hide_lemma=access_implies_issued,
                           hide_lemma=refresh_used_implies_issued]:
  exists-trace "∃ t cid pk #i. Token_Issued( t, cid, pk ) @ #i"
/*
guarded formula characterizing all satisfying traces:
"∃ t cid pk #i. (Token_Issued( t, cid, pk ) @ #i)"
*/
simplify
solve( AuthzCode( authorization_code, cid, pk(x), iss ) ▶₁ #i )
  case AS_VerifyROPC_SendCode_ROPCStep5_6
  solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), ~iss ) ▶₂ #i )
    case AS_VerifyJWTAndDPoPP_ToBackend_Step10
    solve( !AS_Identity( ~iss ) ▶₆ #i )
      case Setup_AS_Identity
      solve( In_S( $Backend, $AS,
                   <'token_req_b2as', ~ClientID, ~authorization_code, 
                    sign(<DPoP_Params_TE, 'token_endpoint'>, x), pk(x), DPoP_Params_TE>
             ) ▶₀ #i )
        case ChanIn_S
        solve( In_S( $Backend.1, $AS.1,
                     <'ropc_auth_b2as', sign(<DPoP_Params, ~password>, x), pk(x), 
                      DPoP_Params, ~password, ~ClientID>
               ) ▶₀ #vr )
          case ChanIn_S
          solve( In_S( $Backend.2, $AS.2,
                       <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                        sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                        sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                              sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                             ~backend_sk), 
                        sign(<DPoP_Params.1, ~nonce>, x), pk(x), DPoP_Params.1, pk(x)>
                 ) ▶₀ #vr.2 )
            case ChanIn_S
            solve( In_S( $Backend.3, $AS.3, <'step2_b2as', ~ClientID>
                   ) ▶₀ #vr.3 )
              case ChanIn_S
              solve( In_S( $Backend.4, $Client,
                           <'step3_b2c', ~ClientID, nonce.1, iss.1>
                     ) ▶₀ #vr.8 )
                case ChanIn_S
                solve( In_S( $Backend.5, $Client.1,
                             <'step3_b2c', ~ClientID, nonce.2, iss.2>
                       ) ▶₀ #vr.9 )
                  case ChanIn_S
                  solve( In_S( $Backend.7, $AS.4,
                               <'step9_b2as', ~ClientID, ~nonce.3, Device_Info.2, 
                                sign(<Device_Info.2, ~nonce.3, pk(x)>, ~aa_sk), 
                                sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce.3, 
                                      sign(<Device_Info.2, ~nonce.3, pk(x)>, ~aa_sk)>,
                                     ~backend_sk.1), 
                                sign(<DPoP_Params.2, ~nonce.3>, x), pk(x), DPoP_Params.2, pk(x)>
