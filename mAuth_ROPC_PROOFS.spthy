                                                                              'client-attestation+jwt', 
                                                                              ~ClientID.1, pk(x), 
                                                                              ~nonce.2, 
                                                                              sign(<Device_Info.2, 
                                                                                    ~nonce.2, pk(x)
                                                                                   >,
                                                                                   ~aa_sk)
                                                                             >,
                                                                             ~backend_sk.2), 
                                                                        sign(<DPoP_Params.4, 
                                                                              ~nonce.2>,
                                                                             x), 
