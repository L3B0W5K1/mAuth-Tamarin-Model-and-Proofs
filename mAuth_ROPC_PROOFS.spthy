lemma S6_backend_key_secrecy:
  all-traces
  "∀ k #i.
    (Secret_BackendKey( k ) @ #i) ⇒
    ((¬(∃ #j. K( k ) @ #j)) ∨ (∃ #r. RevealBackend( k ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ k #i.
  (Secret_BackendKey( k ) @ #i)
 ∧
  (∃ #j. (K( k ) @ #j)) ∧ (∀ #r. (RevealBackend( k ) @ #r) ⇒ ⊥)"
*/
simplify
solve( !KU( ~backend_sk ) @ #vk )
  case Reveal_Backend_Key
  by contradiction /* from formulas */
qed

lemma Z1_code_after_attestation:
  all-traces
  "∀ code ClientID pkC iss #i.
    (AuthzCode_Issued( code, ClientID, pkC, iss ) @ #i) ⇒
    ((∃ nonce #j #k.
       (((AS_Issued_Nonce( nonce ) @ #j) ∧
         (AA_Signed_Attestation( nonce, pkC ) @ #k)) ∧
        (#j < #k)) ∧
       (#k < #i)) ∨
     (∃ aa_sk #r. RevealAA( aa_sk ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ code ClientID pkC iss #i.
  (AuthzCode_Issued( code, ClientID, pkC, iss ) @ #i)
 ∧
  (∀ nonce #j #k.
    (AS_Issued_Nonce( nonce ) @ #j) ∧
    (AA_Signed_Attestation( nonce, pkC ) @ #k)
   ⇒
    ((¬(#j < #k)) ∨ (¬(#k < #i)))) ∧
  (∀ aa_sk #r. (RevealAA( aa_sk ) @ #r) ⇒ ⊥)"
*/
simplify
solve( !AS_StoredCredentials( password ) ▶₁ #i )
  case Setup_User_Credentials
  solve( !AS_Client_Tied_PublicKey( ClientID, pk(x), iss ) ▶₂ #i )
    case AS_VerifyJWTAndDPoPP_ToBackend_Step10
    solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce, iss.1
           ) ▶₁ #j )
      case AS_IssueChallenge_ToBackend_Step3
      solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j )
        case Setup_AA_Enclave
        solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j )
          case Setup_Backend_Identity
          solve( !AS_Identity( ~iss.1 ) ▶₄ #j )
            case Setup_AS_Identity
            solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.1,
                                                       iss.2
                   ) ▶₁ #j.1 )
              case AS_IssueChallenge_ToBackend_Step3
              solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.1 )
                case Setup_AA_Enclave
                solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.1 )
                  case Setup_Backend_Identity
                  solve( !AS_Identity( ~iss.2 ) ▶₄ #j.1 )
                    case Setup_AS_Identity
                    solve( In_S( $Backend, $AS,
                                 <'ropc_auth_b2as', sign(<DPoP_Params, ~password>, x), pk(x), 
                                  DPoP_Params, ~password, ~ClientID>
                           ) ▶₀ #i )
                      case ChanIn_S
                      solve( In_S( $Backend.1, $AS.1,
                                   <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                                    sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                                    sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                          sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                         ~backend_sk), 
                                    sign(<DPoP_Params.1, ~nonce>, x), pk(x), DPoP_Params.1, pk(x)>
                             ) ▶₀ #j )
                        case ChanIn_S
                        solve( In_S( $Backend.2, $AS.2,
                                     <'step9_b2as', ~ClientID, ~nonce.1, Device_Info.1, 
                                      sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk), 
                                      sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce.1, 
                                            sign(<Device_Info.1, ~nonce.1, pk(x)>, ~aa_sk)>,
                                           ~backend_sk.1), 
                                      sign(<DPoP_Params.2, ~nonce.1>, x), pk(x), DPoP_Params.2, 
                                      pk(x)>
                               ) ▶₀ #j.1 )
                          case ChanIn_S
                          solve( In_S( $Backend.3, $AS.3,
                                       <'step9_b2as', ~ClientID, ~nonce.2, Device_Info.2, 
                                        sign(<Device_Info.2, ~nonce.2, pk(x)>, ~aa_sk), 
                                        sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce.2, 
                                              sign(<Device_Info.2, ~nonce.2, pk(x)>, ~aa_sk)>,
                                             ~backend_sk.2), 
                                        sign(<DPoP_Params.3, ~nonce.2>, x), pk(x), DPoP_Params.3, 
                                        pk(x)>
                                 ) ▶₀ #vr.1 )
                            case ChanIn_S
                            solve( In_S( $Backend.4, $AS.4, <'step2_b2as', ~ClientID>
                                   ) ▶₀ #vr.2 )
                              case ChanIn_S
                              solve( In_S( $Backend.5, $Client,
                                           <'step3_b2c', ~ClientID, nonce.3, iss.3>
                                     ) ▶₀ #vr.7 )
                                case ChanIn_S
                                solve( In_S( $Backend.7, $AS.5, <'step2_b2as', ~ClientID>
                                       ) ▶₀ #vr.9 )
                                  case ChanIn_S
                                  solve( In_S( $Backend.8, $AS.6, <'step2_b2as', ~ClientID>
                                         ) ▶₀ #vr.12 )
                                    case ChanIn_S
                                    solve( In_S( $Client.2, $Backend,
                                                 <'ropc_auth_c2b', 
                                                  sign(<DPoP_Params, ~password>, x), pk(x), 
                                                  DPoP_Params, ~password, ~ClientID>
                                           ) ▶₀ #vr.17 )
                                      case ChanIn_S
                                      solve( In_S( $Client.3, $Backend.1,
                                                   <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                                    sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk), 
                                                    sign(<'client-attestation+jwt', ~ClientID, 
                                                          pk(~skC), ~nonce, 
                                                          sign(<Device_Info, ~nonce, pk(~skC)>,
                                                               ~aa_sk)
                                                         >,
                                                         ~backend_sk), 
                                                    sign(<DPoP_Params, ~nonce>, ~skC), pk(~skC), 
                                                    DPoP_Params, pk(~skC)>
                                             ) ▶₀ #vr.20 )
                                        case ChanIn_S
                                        by contradiction /* from formulas */
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma Z2_no_double_redeem:
  all-traces
  "¬(∃ code ClientID1 ClientID2 pkC1 pkC2 #i #j.
      ((AuthzCode_Redeemed( code, ClientID1, pkC1 ) @ #i) ∧
       (AuthzCode_Redeemed( code, ClientID2, pkC2 ) @ #j)) ∧
      (¬(#i = #j)))"
/*
guarded formula characterizing all counter-examples:
"∃ code ClientID1 ClientID2 pkC1 pkC2 #i #j.
  (AuthzCode_Redeemed( code, ClientID1, pkC1 ) @ #i) ∧
  (AuthzCode_Redeemed( code, ClientID2, pkC2 ) @ #j)
 ∧
  ¬(#i = #j)"
*/
simplify
by contradiction /* from formulas */

lemma Z3_no_auth_code_substitution:
  all-traces
  "∀ code ClientID1 ClientID2 pkC1 pkC2 iss #i #j.
    ((AuthzCode_Issued( code, ClientID1, pkC1, iss ) @ #i) ∧
     (AuthzCode_Redeemed( code, ClientID2, pkC2 ) @ #j)) ⇒
    ((ClientID1 = ClientID2) ∧ (pkC1 = pkC2))"
/*
guarded formula characterizing all counter-examples:
"∃ code ClientID1 ClientID2 pkC1 pkC2 iss #i #j.
  (AuthzCode_Issued( code, ClientID1, pkC1, iss ) @ #i) ∧
  (AuthzCode_Redeemed( code, ClientID2, pkC2 ) @ #j)
 ∧
  ((¬(ClientID1 = ClientID2)) ∨ (¬(pkC1 = pkC2)))"
*/
simplify
solve( (¬(ClientID1 = ClientID2))  ∥ (¬(pk(x) = pk(x.1))) )
  case case_1
  solve( !AS_StoredCredentials( password ) ▶₁ #i )
    case Setup_User_Credentials
    solve( !AS_Client_Tied_PublicKey( ClientID1, pk(x), iss ) ▶₂ #i )
      case AS_VerifyJWTAndDPoPP_ToBackend_Step10
      solve( AuthzCode( ~authorization_code, ClientID2, pk(x.1), iss.1
             ) ▶₁ #j )
        case AS_VerifyROPC_SendCode_ROPCStep5_6
        by contradiction /* from formulas */
      qed
    qed
  qed
next
  case case_2
  solve( !AS_StoredCredentials( password ) ▶₁ #i )
    case Setup_User_Credentials
    solve( !AS_Client_Tied_PublicKey( ClientID1, pk(x), iss ) ▶₂ #i )
      case AS_VerifyJWTAndDPoPP_ToBackend_Step10
      solve( AuthzCode( ~authorization_code, ClientID2, pk(x.1), iss.1
             ) ▶₁ #j )
        case AS_VerifyROPC_SendCode_ROPCStep5_6
        by contradiction /* from formulas */
      qed
    qed
  qed
qed

lemma Z4_code_unique_issuance:
  all-traces
  "∀ code ClientID1 ClientID2 pkC1 pkC2 iss1 iss2 #i #j.
    ((AuthzCode_Issued( code, ClientID1, pkC1, iss1 ) @ #i) ∧
     (AuthzCode_Issued( code, ClientID2, pkC2, iss2 ) @ #j)) ⇒
    ((((#i = #j) ∧ (ClientID1 = ClientID2)) ∧ (pkC1 = pkC2)) ∧
     (iss1 = iss2))"
/*
guarded formula characterizing all counter-examples:
"∃ code ClientID1 ClientID2 pkC1 pkC2 iss1 iss2 #i #j.
  (AuthzCode_Issued( code, ClientID1, pkC1, iss1 ) @ #i) ∧
  (AuthzCode_Issued( code, ClientID2, pkC2, iss2 ) @ #j)
 ∧
  ((¬(#i = #j)) ∨
   (¬(ClientID1 = ClientID2)) ∨
   (¬(pkC1 = pkC2)) ∨
   (¬(iss1 = iss2)))"
*/
simplify
by contradiction /* from formulas */

lemma T1_stolen_token_unusable:
  all-traces
  "∀ token pkC ClientID #i #j.
    ((LeakToken( token, pkC ) @ #i) ∧
     (Token_Used_For_Access( token, ClientID, pkC ) @ #j)) ⇒
    ((∃ params ctx #k #l.
       (((Client_Created_DPoP( pkC, params, ctx ) @ #k) ∧
         (DPoP_Verified( params, pkC ) @ #l)) ∧
        (#k < #l)) ∧
       (#l < #j)) ∨
     (∃ skC #r. RevealClientKey( ClientID, skC ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ token pkC ClientID #i #j.
  (LeakToken( token, pkC ) @ #i) ∧
  (Token_Used_For_Access( token, ClientID, pkC ) @ #j)
 ∧
  (∀ params ctx #k #l.
    (Client_Created_DPoP( pkC, params, ctx ) @ #k) ∧
    (DPoP_Verified( params, pkC ) @ #l)
   ⇒
    ((¬(#k < #l)) ∨ (¬(#l < #j)))) ∧
  (∀ skC #r. (RevealClientKey( ClientID, skC ) @ #r) ⇒ ⊥)"
*/
simplify
solve( !ConstrainedAccess( ~constrained_access_token, pk(x)
       ) ▶₀ #i )
  case AS_TokenAns_ToBackend_Step13
  solve( !ConstrainedAccess( ~constrained_access_token, pk(x)
         ) ▶₁ #j )
    case AS_TokenAns_ToBackend_Step13
    solve( !ConstrainedReference( DPoP_reference_token, pk(x), iss
           ) ▶₂ #j )
      case AS_TokenAns_ToBackend_Step13
      solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), ~iss ) ▶₃ #j )
        case AS_VerifyJWTAndDPoPP_ToBackend_Step10
        solve( !AS_Identity( ~iss ) ▶₄ #j )
          case Setup_AS_Identity
          solve( !AS_StoredCredentials( password.1 ) ▶₁ #j.2 )
            case Setup_User_Credentials
            solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), iss.2
                   ) ▶₂ #j.2 )
              case AS_VerifyJWTAndDPoPP_ToBackend_Step10
              solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.1,
                                                         iss.3
                     ) ▶₁ #j.3 )
                case AS_IssueChallenge_ToBackend_Step3
                solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.3 )
                  case Setup_AA_Enclave
                  solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.3 )
                    case Setup_Backend_Identity
                    solve( !AS_Identity( ~iss.3 ) ▶₄ #j.3 )
                      case Setup_AS_Identity
                      solve( !AS_StoredCredentials( password.2 ) ▶₁ #j.4 )
                        case Setup_User_Credentials
                        solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), iss.4
                               ) ▶₂ #j.4 )
                          case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                          solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.3,
                                                                     iss.5
                                 ) ▶₁ #j.5 )
                            case AS_IssueChallenge_ToBackend_Step3
                            solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.5 )
                              case Setup_AA_Enclave
                              solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.5 )
                                case Setup_Backend_Identity
                                solve( !AS_Identity( ~iss.5 ) ▶₄ #j.5 )
                                  case Setup_AS_Identity
                                  solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID, nonce.4,
                                                                             iss.6
                                         ) ▶₁ #j.6 )
                                    case AS_IssueChallenge_ToBackend_Step3
                                    solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.6 )
                                      case Setup_AA_Enclave
                                      solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.6 )
                                        case Setup_Backend_Identity
                                        solve( !AS_Identity( ~iss.6 ) ▶₄ #j.6 )
                                          case Setup_AS_Identity
                                          solve( !AS_StoredCredentials( password.3 ) ▶₁ #j.7 )
                                            case Setup_User_Credentials
                                            solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x),
                                                                              iss.7
                                                   ) ▶₂ #j.7 )
                                              case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                                              solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID,
                                                                                         nonce.5,
                                                                                         iss.8
                                                     ) ▶₁ #j.8 )
                                                case AS_IssueChallenge_ToBackend_Step3
                                                solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.8 )
                                                  case Setup_AA_Enclave
                                                  solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.8 )
                                                    case Setup_Backend_Identity
                                                    solve( !AS_Identity( ~iss.8 ) ▶₄ #j.8 )
                                                      case Setup_AS_Identity
                                                      solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID,
                                                                                                 nonce.6,
                                                                                                 iss.9
                                                             ) ▶₁ #j.9 )
                                                        case AS_IssueChallenge_ToBackend_Step3
                                                        solve( !PkAA( ~ClientID, pk(x.1) ) ▶₂ #j.9 )
                                                          case Setup_AA_Enclave
                                                          solve( !AS_Knows_Backend( pk(x.1)
                                                                 ) ▶₃ #j.9 )
                                                            case Setup_Backend_Identity
                                                            solve( !AS_Identity( ~iss.9 ) ▶₄ #j.9 )
                                                              case Setup_AS_Identity
                                                              solve( !AS_StoredCredentials( password.4
                                                                     ) ▶₁ #j.10 )
                                                                case Setup_User_Credentials
                                                                solve( !AS_Client_Tied_PublicKey( ~ClientID,
                                                                                                  pk(x),
