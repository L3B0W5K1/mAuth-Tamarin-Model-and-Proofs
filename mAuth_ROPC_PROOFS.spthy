theory mAuth_Scenario2_ROPC begin

// Function signature and definition of the equational theory E

functions: fst/1, pair/2, pk/1, sign/2, snd/1, true/0, verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true



heuristic: S



rule (modulo E) ChanOut_S:
   [ Out_S( $A, $B, x ) ]
  --[ ChanOut_S( $A, $B, x ) ]->
   [ Sec( $A, $B, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ChanIn_S:
   [ Sec( $A, $B, x ) ]
  --[ ChanIn_S( $A, $B, x ) ]->
   [ In_S( $A, $B, x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup_AS_Identity[role=AS]:
   [ Fr( ~iss ) ] --> [ !AS_Identity( ~iss ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup_Resource_Server[role=RS]:
   [ Fr( ~data ) ] --> [ !RS_Resource( ~data ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup_Backend_Identity[role=Backend]:
   [ Fr( ~backend_sk ) ]
  --[ Secret_BackendKey( ~backend_sk ) ]->
   [
   !Backend_Ltk( ~backend_sk ), !PkBackend( pk(~backend_sk) ),
   !AS_Knows_Backend( pk(~backend_sk) )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup_User_Credentials:
   [ Fr( ~password ) ]
  --[ Secret_UserPassword( ~password ) ]->
   [ !UserPassword( ~password ), !AS_StoredCredentials( ~password ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Client_AttestChallReq_ToBackend_Step2[role=Client]:
   [ Fr( ~ClientID ) ]
  -->
   [
   Out_S( $Client, $Backend, <'step2_c2b', ~ClientID> ),
   Client_KeygenSlot( ~ClientID )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Backend_AttestChallReq_ToAS_Step2[role=Backend]:
   [ In_S( $Client, $Backend, <'step2_c2b', ClientID> ) ]
  -->
   [ Out_S( $Backend, $AS, <'step2_b2as', ClientID> ) ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) AS_IssueChallenge_ToBackend_Step3[role=AS]:
   [
   In_S( $Backend, $AS, <'step2_b2as', ClientID> ), Fr( ~nonce ),
   !AS_Identity( iss )
   ]
  --[
  AS_Issued_Nonce( ~nonce ),
  AS_Request_Accepted( <'challenge', ~nonce> )
  ]->
   [
   Out_S( $AS, $Backend, <'step3_as2b', ClientID, ~nonce, iss> ),
   AS_Pending_Challenge_Nonce_Useable( ClientID, ~nonce, iss )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Backend_IssueChallenge_ToClient_Step3[role=Backend]:
   [ In_S( $AS, $Backend, <'step3_as2b', ClientID, nonce, iss> ) ]
  -->
   [ Out_S( $Backend, $Client, <'step3_b2c', ClientID, nonce, iss> ) ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Client_GenerateKey_ToClient_Step4[role=Client]:
   [
   In_S( $Backend, $Client, <'step3_b2c', ClientID, nonce, iss> ),
   Fr( ~skC )
   ]
  --[
  Secret_ClientKey( ClientID, ~skC ),
  Client_Key_In_Hardware( pk(~skC) ),
  Client_Learned_Iss( ClientID, iss )
  ]->
   [
   Client_GenerateKey_ToClient_Step4( ClientID, nonce ),
   !Client_Key( ClientID, ~skC, pk(~skC) ),
   !Client_Expected_Iss( ClientID, iss )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Client_RequestAttestation_ToAA_Step5[role=Client]:
   [
   Client_GenerateKey_ToClient_Step4( ClientID, nonce ),
   !Client_Key( ClientID, skC, pkC ), Client_KeygenSlot( ClientID ),
   Fr( ~Device_Info )
   ]
  --[ Client_Sent_Attestation_Request( ClientID, nonce, pkC ) ]->
   [
   Client_RequestAttestation_ToAA_Step5( <~Device_Info, nonce, pkC> ),
   Client_AttestRequestPending_ToClient_Step5To8( ClientID, nonce,
                                                  ~Device_Info
   ),
   Client_ClientIDForKeygen_ToAA( ClientID )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Setup_AA_Enclave[role=AA]:
   [ Client_ClientIDForKeygen_ToAA( ClientID ), Fr( ~aa_sk ) ]
  --[ Secret_AAKey( ~aa_sk ) ]->
   [ !AA_Ltk( ~aa_sk ), !PkAA( ClientID, pk(~aa_sk) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) AA_SignAttestation_ToAA_Step6[role=AA]:
   [
   Client_RequestAttestation_ToAA_Step5( <Device_Info, nonce, pkC> ),
   !AA_Ltk( aa_sk )
   ]
  --[ AA_Signed_Attestation( nonce, pkC ), AA_NonceUsed( nonce ) ]->
   [
   AA_SignAttestation_ToAA_Step6( sign(<Device_Info, nonce, pkC>,
                                       aa_sk)
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) AA_SendAttestation_ToClient_Step7[role=AA]:
   [ AA_SignAttestation_ToAA_Step6( attestJWT ) ]
  -->
   [ AA_SendAttestation_ToClient_Step7( attestJWT ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Client_ForwardPlatformAttest_ToBackend_Step7b[role=Client]:
   [
   AA_SendAttestation_ToClient_Step7( platformAttest ),
   Client_AttestRequestPending_ToClient_Step5To8( ClientID, nonce,
                                                  Device_Info
   ),
   !Client_Key( ClientID, skC, pkC )
   ]
  -->
   [
   Out_S( $Client, $Backend,
          <'wrap_cat_c2b', ClientID, nonce, pkC, Device_Info, platformAttest>
   ),
   Client_AwaitingCAT_ToClient( ClientID, nonce, Device_Info,
                                platformAttest, pkC
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Backend_WrapCAT_ToClient_Step7c[role=Backend]:
   [
   In_S( $Client, $Backend,
         <'wrap_cat_c2b', ClientID, nonce, pkC, Device_Info, platformAttest>
   ),
   !Backend_Ltk( backend_sk )
   ]
  --[ Backend_Issued_CAT( ClientID, pkC, nonce ) ]->
   [
   Out_S( $Backend, $Client,
          <'cat_response_b2c', ClientID, 
           sign(<'client-attestation+jwt', ClientID, pkC, nonce, 
                 platformAttest>,
                backend_sk), 
           platformAttest>
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Client_CreateDPoPP_ToClient_Step8[role=Client]:
   [
   In_S( $Backend, $Client,
         <'cat_response_b2c', ClientID, clientAttestJWT, platformAttest>
   ),
   Client_AwaitingCAT_ToClient( ClientID, nonce, Device_Info,
                                platformAttest, pkC
   ),
   !Client_Key( ClientID, skC, pkC ), Fr( ~DPoP_Params )
   ]
  --[ Client_Created_DPoP( pkC, ~DPoP_Params, 'authz' ) ]->
   [
   Client_DPoPAttestation_ToClient_Step8( ClientID, nonce,
                                          clientAttestJWT, platformAttest, Device_Info
   ),
   Client_CreateDPoPP_ToClient_Step8( sign(<~DPoP_Params, nonce>,
                                           skC),
                                      pkC, ~DPoP_Params, nonce
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Client_SendAuthzReq_ToBackend_Step9[role=Client]:
   [
   Client_DPoPAttestation_ToClient_Step8( ClientID, nonce,
                                          clientAttestJWT, platformAttest, Device_Info
   ),
   Client_CreateDPoPP_ToClient_Step8( dpopp, pkC, DPoP_Params, nonce )
   ]
  -->
   [
   Out_S( $Client, $Backend,
          <'step9_c2b', ClientID, nonce, Device_Info, platformAttest, 
           clientAttestJWT, dpopp, pkC, DPoP_Params, pkC>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Backend_SendAuthzReq_ToAS_Step9[role=Backend]:
   [
   In_S( $Client, $Backend,
         <'step9_c2b', ClientID, nonce, Device_Info, platformAttest, 
          clientAttestJWT, dpopp, pkC, DPoP_Params, dpop_jkt>
   )
   ]
  -->
