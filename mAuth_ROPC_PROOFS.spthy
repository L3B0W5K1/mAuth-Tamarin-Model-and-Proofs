lemma ROPC5_ropc_requires_dpop:
  all-traces
  "∀ ClientID #i.
    (ROPC_Auth_Success( ClientID ) @ #i) ⇒
    (∃ params pkC #j.
      (DPoP_Verified( params, pkC ) @ #j) ∧
      (∃ #k.
        (AS_Accepted_Client_Key( ClientID, pkC ) @ #k) ∧ (#k < #i)))"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID #i.
  (ROPC_Auth_Success( ClientID ) @ #i)
 ∧
  ∀ params pkC #j.
   (DPoP_Verified( params, pkC ) @ #j)
  ⇒
   ∀ #k. (AS_Accepted_Client_Key( ClientID, pkC ) @ #k) ⇒ ¬(#k < #i)"
*/
simplify
by contradiction /* from formulas */

