lemma SANITY_dpop_verified [hide_lemma=R2_dpop_requires_creation,
                            hide_lemma=B1_attestation_unforgeable,
                            hide_lemma=B2_as_requires_attestation,
                            hide_lemma=B3_token_implies_attestation,
                            hide_lemma=accept_implies_hardware,
                            hide_lemma=I1_token_requires_hardware_key,
                            hide_lemma=accept_unique_pkC, hide_lemma=client_iss_unique,
                            hide_lemma=token_implies_code, hide_lemma=code_implies_accept,
                            hide_lemma=access_implies_issued,
                            hide_lemma=refresh_used_implies_issued]:
  exists-trace "∃ p pk #i. DPoP_Verified( p, pk ) @ #i"
/*
guarded formula characterizing all satisfying traces:
"∃ p pk #i. (DPoP_Verified( p, pk ) @ #i)"
*/
simplify
solve( DPoP_Verified( p, pk ) @ #i )
  case AS_VerifyJWTAndDPoPP_ToBackend_Step10
  solve( AS_Pending_Challenge_Nonce_Useable( ClientID, nonce, iss
         ) ▶₁ #i )
    case AS_IssueChallenge_ToBackend_Step3
    solve( !PkAA( ClientID, pk(x.1) ) ▶₂ #i )
      case Setup_AA_Enclave
      solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #i )
        case Setup_Backend_Identity
        solve( !AS_Identity( ~iss ) ▶₄ #i )
          case Setup_AS_Identity
          solve( In_S( $Backend, $AS,
                       <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                        sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                        sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                              sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                             ~backend_sk), 
                        sign(<p, ~nonce>, x), pk(x), p, pk(x)>
                 ) ▶₀ #i )
            case ChanIn_S
            solve( In_S( $Backend.1, $AS.1, <'step2_b2as', ~ClientID>
                   ) ▶₀ #vr )
              case ChanIn_S
              solve( In_S( $Backend.2, $Client,
                           <'step3_b2c', ~ClientID, nonce.1, iss.1>
                     ) ▶₀ #vr.4 )
                case ChanIn_S
                solve( In_S( $Backend.3, $Client.1,
                             <'step3_b2c', ~ClientID, nonce.2, iss.2>
                       ) ▶₀ #vr.5 )
                  case ChanIn_S
                  solve( In_S( $Client.3, $Backend,
                               <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                                sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                      sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                     ~backend_sk), 
                                sign(<p, ~nonce>, x), pk(x), p, pk(x)>
                         ) ▶₀ #vr.10 )
                    case ChanIn_S
                    solve( In_S( $Client.4, $Backend.1, <'step2_c2b', ~ClientID>
                           ) ▶₀ #vr.13 )
                      case ChanIn_S
                      solve( In_S( $AS.2, $Backend.2,
                                   <'step3_as2b', ~ClientID, ~nonce, iss.1>
                             ) ▶₀ #vr.16 )
                        case ChanIn_S
                        solve( In_S( $AS.2, $Backend.2,
                                     <'step3_as2b', ~ClientID, nonce.1, iss.1>
                               ) ▶₀ #vr.19 )
                          case ChanIn_S
                          solve( In_S( $Backend.3, $Client.4,
                                       <'cat_response_b2c', ~ClientID, 
                                        sign(<'client-attestation+jwt', ~ClientID, pk(~skC), 
                                              ~nonce, sign(<~Device_Info, ~nonce, pk(~skC)>, ~aa_sk)
                                             >,
                                             ~backend_sk), 
                                        sign(<~Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>
                                 ) ▶₀ #vr.23 )
                            case ChanIn_S
                            solve( In_S( $Backend.2, $AS.2, <'step2_b2as', ~ClientID>
                                   ) ▶₀ #vr.33 )
                              case ChanIn_S
                              solve( In_S( $Client.4, $Backend.3,
                                           <'wrap_cat_c2b', ~ClientID, ~nonce, pk(~skC), 
                                            Device_Info.1, 
                                            sign(<~Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>
                                     ) ▶₀ #vr.37 )
                                case ChanIn_S
                                solve( In_S( $Client.5, $Backend.2, <'step2_c2b', ~ClientID>
                                       ) ▶₀ #vr.40 )
                                  case ChanIn_S
                                  SOLVED // trace found
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

