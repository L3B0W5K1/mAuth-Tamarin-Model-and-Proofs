    ((LeakRefreshToken( token, pkC ) @ #i) ∧
     (RefreshToken_Used( token, ClientID, pkC ) @ #j)) ⇒
    ((∃ params ctx #k.
       (Client_Created_DPoP( pkC, params, ctx ) @ #k) ∧ (#k < #j)) ∨
     (∃ skC #k. RevealClientKey( ClientID, skC ) @ #k))"
