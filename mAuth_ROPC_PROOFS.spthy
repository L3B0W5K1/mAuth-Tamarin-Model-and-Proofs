restriction Equality:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

restriction unique_dpopp:
  "∀ params #i #j.
    ((DPoP_Used( params ) @ #i) ∧ (DPoP_Used( params ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

restriction no_replay:
  "∀ id #i #j.
    ((AS_Request_Accepted( id ) @ #i) ∧
     (AS_Request_Accepted( id ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

restriction unique_attestation_per_nonce:
  "∀ nonce pkC1 pkC2 #i #j.
    ((AA_Signed_Attestation( nonce, pkC1 ) @ #i) ∧
     (AA_Signed_Attestation( nonce, pkC2 ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

lemma typing [sources]:
  all-traces
  "(((∀ t cid pk #i #j.
       ((Token_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)) ⇒
       (∃ #l. (LeakToken( t, pk ) @ #l) ∧ (#l < #i))) ∧
     (∀ t cid pk #i #j.
       ((RefToken_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)) ⇒
       (∃ #l. (LeakRefToken( t, pk ) @ #l) ∧ (#l < #i)))) ∧
    (∀ t cid pk #i #j.
      ((RefreshToken_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)) ⇒
      (∃ #l. (LeakRefreshToken( t, pk ) @ #l) ∧ (#l < #i)))) ∧
   (∀ c cid pk iss #i #j.
     ((AuthzCode_Issued( c, cid, pk, iss ) @ #j) ∧ (!KU( c ) @ #i)) ⇒
     (⊥))"
/*
guarded formula characterizing all counter-examples:
"((∃ t cid pk #i #j.
    (Token_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)
   ∧
    ∀ #l. (LeakToken( t, pk ) @ #l) ⇒ ¬(#l < #i)) ∨
  (∃ t cid pk #i #j.
    (RefToken_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)
   ∧
    ∀ #l. (LeakRefToken( t, pk ) @ #l) ⇒ ¬(#l < #i)) ∨
  (∃ t cid pk #i #j.
    (RefreshToken_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)
   ∧
    ∀ #l. (LeakRefreshToken( t, pk ) @ #l) ⇒ ¬(#l < #i)) ∨
  (∃ c cid pk iss #i #j.
    (AuthzCode_Issued( c, cid, pk, iss ) @ #j) ∧ (!KU( c ) @ #i)))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( (∃ t cid pk #i #j.
           (Token_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)
          ∧
           ∀ #l. (LeakToken( t, pk ) @ #l) ⇒ ¬(#l < #i))  ∥
         (∃ t cid pk #i #j.
           (RefToken_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)
          ∧
           ∀ #l. (LeakRefToken( t, pk ) @ #l) ⇒ ¬(#l < #i))  ∥
         (∃ t cid pk #i #j.
           (RefreshToken_Issued( t, cid, pk ) @ #j) ∧ (!KU( t ) @ #i)
          ∧
           ∀ #l. (LeakRefreshToken( t, pk ) @ #l) ⇒ ¬(#l < #i))  ∥
         (∃ c cid pk iss #i #j.
           (AuthzCode_Issued( c, cid, pk, iss ) @ #j) ∧ (!KU( c ) @ #i)) )
    case case_1
    solve( (last(#j))  ∥ (last(#i))  ∥
           (∃ #l.
             (LeakToken( ~constrained_access_token, pk(x) ) @ #l)
            ∧
             (¬(last(#l))) ∧ (#l < #i)) )
      case case_1
      solve( AuthzCode( authorization_code, cid, pk(x), iss ) ▶₁ #j )
        case AS_VerifyROPC_SendCode_ROPCStep5_6
        solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), ~iss ) ▶₂ #j )
          case AS_VerifyJWTAndDPoPP_ToBackend_Step10
          solve( !AS_Identity( ~iss ) ▶₆ #j )
            case Setup_AS_Identity
            solve( In_S( $Backend, $AS,
                         <'token_req_b2as', ~ClientID, ~authorization_code, 
                          sign(<DPoP_Params_TE, 'token_endpoint'>, x), pk(x), DPoP_Params_TE>
                   ) ▶₀ #j )
              case ChanIn_S
              solve( In_S( $Backend.1, $AS.1,
                           <'ropc_auth_b2as', sign(<DPoP_Params, ~password>, x), pk(x), 
                            DPoP_Params, ~password, ~ClientID>
                     ) ▶₀ #vr )
                case ChanIn_S
                solve( In_S( $Backend.2, $AS.2,
                             <'step9_b2as', ~ClientID, ~nonce, Device_Info, 
                              sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk), 
                              sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce, 
                                    sign(<Device_Info, ~nonce, pk(x)>, ~aa_sk)>,
                                   ~backend_sk), 
                              sign(<DPoP_Params.1, ~nonce>, x), pk(x), DPoP_Params.1, pk(x)>
                       ) ▶₀ #vr.2 )
                  case ChanIn_S
                  solve( In_S( $Backend.3, $AS.3, <'step2_b2as', ~ClientID>
                         ) ▶₀ #vr.3 )
                    case ChanIn_S
                    solve( In_S( $Backend.4, $Client,
                                 <'step3_b2c', ~ClientID, nonce.1, iss.1>
                           ) ▶₀ #vr.8 )
                      case ChanIn_S
                      solve( In_S( $Backend.5, $Client.1,
                                   <'step3_b2c', ~ClientID, nonce.2, iss.2>
                             ) ▶₀ #vr.9 )
                        case ChanIn_S
                        solve( In_S( $Backend.7, $AS.4,
                                     <'step9_b2as', ~ClientID, ~nonce.3, Device_Info.2, 
                                      sign(<Device_Info.2, ~nonce.3, pk(x)>, ~aa_sk), 
                                      sign(<'client-attestation+jwt', ~ClientID, pk(x), ~nonce.3, 
                                            sign(<Device_Info.2, ~nonce.3, pk(x)>, ~aa_sk)>,
                                           ~backend_sk.1), 
                                      sign(<DPoP_Params.2, ~nonce.3>, x), pk(x), DPoP_Params.2, 
                                      pk(x)>
                               ) ▶₀ #vr.11 )
                          case ChanIn_S
                          solve( In_S( $Backend.8, $AS.5, <'step2_b2as', ~ClientID>
                                 ) ▶₀ #vr.12 )
                            case ChanIn_S
                            solve( In_S( $Client.3, $Backend,
                                         <'dpop_for_token_c2b', 
                                          sign(<DPoP_Params_TE, 'token_endpoint'>, x), pk(x), 
                                          DPoP_Params_TE, ~ClientID>
                                   ) ▶₀ #vr.16 )
                              case ChanIn_S
                              solve( In_S( $AS.6, $Backend.9,
                                           <'auth_completed_as2b', ~ClientID, ~authorization_code>
                                     ) ▶₀ #vr.17 )
                                case ChanIn_S
                                solve( In_S( $Client.5, $Backend.1,
                                             <'ropc_auth_c2b', 
                                              sign(<DPoP_Params, ~password>, ~skC), pk(~skC), 
                                              DPoP_Params, ~password, ~ClientID>
                                       ) ▶₀ #vr.20 )
                                  case ChanIn_S
                                  solve( In_S( $Client.6, $Backend.2,
                                               <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                                sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk), 
                                                sign(<'client-attestation+jwt', ~ClientID, 
                                                      pk(~skC), ~nonce, 
                                                      sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk)
                                                     >,
                                                     ~backend_sk), 
                                                sign(<DPoP_Params, ~nonce>, ~skC), pk(~skC), 
                                                DPoP_Params, pk(~skC)>
                                         ) ▶₀ #vr.23 )
                                    case ChanIn_S
                                    solve( In_S( $Client.7, $Backend.3, <'step2_c2b', ~ClientID>
                                           ) ▶₀ #vr.26 )
                                      case ChanIn_S
                                      solve( In_S( $AS.6, $Backend.4,
                                                   <'step3_as2b', ~ClientID, ~nonce, iss.1>
                                             ) ▶₀ #vr.29 )
                                        case ChanIn_S
