                                         <'step3_b2c', ~ClientID.2, nonce.3, iss.3>
                                   ) ▶₀ #vr.11 )
                              case ChanIn_S
                              solve( In_S( $Client.6, $Backend,
                                           <'step9_c2b', ~ClientID, ~nonce, Device_Info, 
                                            sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk), 
                                            sign(<'client-attestation+jwt', ~ClientID, pk(~skC), 
                                                  ~nonce, 
                                                  sign(<Device_Info, ~nonce, pk(~skC)>, ~aa_sk)>,
                                                 ~backend_sk), 
                                            sign(<DPoP_Params, ~nonce>, ~skC), pk(~skC), 
                                            DPoP_Params, pk(~skC)>
                                     ) ▶₀ #vr.15 )
                                case ChanIn_S
