lemma token_implies_code [reuse]:
  all-traces
  "∀ t cid pk #i.
    (Token_Issued( t, cid, pk ) @ #i) ⇒
    (∃ c iss #j.
      (AuthzCode_Issued( c, cid, pk, iss ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ t cid pk #i.
  (Token_Issued( t, cid, pk ) @ #i)
 ∧
  ∀ c iss #j.
   (AuthzCode_Issued( c, cid, pk, iss ) @ #j) ⇒ ¬(#j < #i)"
*/
simplify
solve( AuthzCode( authorization_code, cid, pk(x), iss ) ▶₁ #i )
  case AS_VerifyROPC_SendCode_ROPCStep5_6
  by contradiction /* from formulas */
qed

lemma code_implies_accept [reuse]:
  all-traces
  "∀ c cid pk iss #i.
    (AuthzCode_Issued( c, cid, pk, iss ) @ #i) ⇒
    (∃ #j. (AS_Accepted_Client_Key( cid, pk ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ c cid pk iss #i.
  (AuthzCode_Issued( c, cid, pk, iss ) @ #i)
 ∧
  ∀ #j. (AS_Accepted_Client_Key( cid, pk ) @ #j) ⇒ ¬(#j < #i)"
*/
simplify
solve( !AS_StoredCredentials( password ) ▶₁ #i )
  case Setup_User_Credentials
  solve( !AS_Client_Tied_PublicKey( cid, pk(x), iss ) ▶₂ #i )
    case AS_VerifyJWTAndDPoPP_ToBackend_Step10
    by contradiction /* from formulas */
  qed
qed

lemma access_implies_issued [reuse, use_induction]:
  all-traces
  "∀ t cid pk #i.
    (Token_Used_For_Access( t, cid, pk ) @ #i) ⇒
    (∃ #j. (Token_Issued( t, cid, pk ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ t cid pk #i.
  (Token_Used_For_Access( t, cid, pk ) @ #i)
 ∧
  ∀ #j. (Token_Issued( t, cid, pk ) @ #j) ⇒ ¬(#j < #i)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( (last(#i))  ∥
         (∃ #j.
           (Token_Issued( t, cid, pk(x) ) @ #j) ∧ (¬(last(#j))) ∧ (#j < #i)) )
    case case_1
    solve( !ConstrainedAccess( t, pk(x) ) ▶₁ #i )
      case AS_TokenAns_ToBackend_Step13
      solve( !ConstrainedReference( DPoP_reference_token, pk(x), iss
             ) ▶₂ #i )
        case AS_TokenAns_ToBackend_Step13
        solve( !AS_Client_Tied_PublicKey( cid, pk(x), ~iss ) ▶₃ #i )
          case AS_VerifyJWTAndDPoPP_ToBackend_Step10
          solve( !AS_Identity( ~iss ) ▶₄ #i )
            case Setup_AS_Identity
            solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID.1, nonce,
                                                       iss.1
                   ) ▶₁ #j )
              case AS_IssueChallenge_ToBackend_Step3
              solve( !PkAA( ~ClientID.1, pk(x.1) ) ▶₂ #j )
                case Setup_AA_Enclave
                solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j )
                  case Setup_Backend_Identity
                  solve( !AS_Identity( ~iss.1 ) ▶₄ #j )
                    case Setup_AS_Identity
                    solve( !AS_StoredCredentials( password ) ▶₁ #j.1 )
                      case Setup_User_Credentials
                      solve( !AS_Client_Tied_PublicKey( ~ClientID.1, pk(x), iss.3
                             ) ▶₂ #j.1 )
                        case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                        solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID.1, nonce.1,
                                                                   iss.4
                               ) ▶₁ #j.2 )
                          case AS_IssueChallenge_ToBackend_Step3
                          solve( !PkAA( ~ClientID.1, pk(x.1) ) ▶₂ #j.2 )
                            case Setup_AA_Enclave
                            solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.2 )
                              case Setup_Backend_Identity
                              solve( !AS_Identity( ~iss.4 ) ▶₄ #j.2 )
                                case Setup_AS_Identity
                                solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID.2, nonce.3,
                                                                           iss.5
                                       ) ▶₁ #j.3 )
                                  case AS_IssueChallenge_ToBackend_Step3
                                  solve( !PkAA( ~ClientID.2, pk(x.1) ) ▶₂ #j.3 )
                                    case Setup_AA_Enclave
                                    solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.3 )
                                      case Setup_Backend_Identity
                                      solve( !AS_Identity( ~iss.5 ) ▶₄ #j.3 )
                                        case Setup_AS_Identity
                                        solve( !AS_StoredCredentials( password.2 ) ▶₁ #j.4 )
                                          case Setup_User_Credentials
                                          solve( !AS_Client_Tied_PublicKey( ~ClientID.2, pk(x),
                                                                            iss.6
                                                 ) ▶₂ #j.4 )
                                            case AS_VerifyJWTAndDPoPP_ToBackend_Step10
                                            solve( AS_Pending_Challenge_Nonce_Useable( ~ClientID.2,
                                                                                       nonce.4,
                                                                                       iss.7
                                                   ) ▶₁ #j.5 )
                                              case AS_IssueChallenge_ToBackend_Step3
                                              solve( !PkAA( ~ClientID.2, pk(x.1) ) ▶₂ #j.5 )
                                                case Setup_AA_Enclave
                                                solve( !AS_Knows_Backend( pk(x.1) ) ▶₃ #j.5 )
                                                  case Setup_Backend_Identity
                                                  solve( !AS_Identity( ~iss.7 ) ▶₄ #j.5 )
                                                    case Setup_AS_Identity
                                                    solve( In_S( $RS, $AS,
                                                                 <'introspect', 
                                                                  ~constrained_access_token, 
                                                                  sign(<DPoP_Params2, 
                                                                        ~DPoP_reference_token>,
                                                                       x), 
                                                                  pk(x), DPoP_Params2, 
                                                                  ~DPoP_reference_token, ~ClientID>
                                                           ) ▶₀ #i )
                                                      case ChanIn_S
                                                      solve( In_S( $Backend.1, $AS.2,
                                                                   <'token_req_b2as', ~ClientID.1, 
                                                                    ~authorization_code, 
                                                                    sign(<DPoP_Params_TE, 
                                                                          'token_endpoint'>,
                                                                         x), 
                                                                    pk(x), DPoP_Params_TE>
                                                             ) ▶₀ #vr )
                                                        case ChanIn_S
                                                        solve( In_S( $Backend.3, $AS.4,
                                                                     <'ropc_auth_b2as', 
                                                                      sign(<DPoP_Params.2, 
                                                                            ~password.1>,
                                                                           x), 
                                                                      pk(x), DPoP_Params.2, 
                                                                      ~password.1, ~ClientID.1>
                                                               ) ▶₀ #vr.1 )
                                                          case ChanIn_S
                                                          solve( In_S( $Backend.5, $AS.6,
                                                                       <'step9_b2as', ~ClientID.1, 
                                                                        ~nonce.2, Device_Info.2, 
                                                                        sign(<Device_Info.2, 
                                                                              ~nonce.2, pk(x)>,
                                                                             ~aa_sk), 
