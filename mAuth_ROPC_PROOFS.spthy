lemma S1_client_key_secrecy:
  all-traces
  "∀ ClientID k #i.
    (Secret_ClientKey( ClientID, k ) @ #i) ⇒
    ((¬(∃ #j. K( k ) @ #j)) ∨
     (∃ #r. RevealClientKey( ClientID, k ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"∃ ClientID k #i.
  (Secret_ClientKey( ClientID, k ) @ #i)
 ∧
  (∃ #j. (K( k ) @ #j)) ∧
  (∀ #r. (RevealClientKey( ClientID, k ) @ #r) ⇒ ⊥)"
*/
simplify
solve( In_S( $Backend, $Client, <'step3_b2c', ClientID, nonce, iss>
       ) ▶₀ #i )
  case ChanIn_S
  solve( In_S( $AS, $Backend, <'step3_as2b', ClientID, nonce, iss>
         ) ▶₀ #vr.2 )
    case ChanIn_S
    solve( In_S( $Backend, $AS, <'step2_b2as', ClientID> ) ▶₀ #vr.5 )
      case ChanIn_S
      solve( In_S( $Client.1, $Backend, <'step2_c2b', ClientID>
             ) ▶₀ #vr.9 )
        case ChanIn_S
        solve( !KU( ~skC ) @ #vk )
          case Reveal_Client_Key
          by contradiction /* from formulas */
        qed
      qed
    qed
  qed
qed

lemma S2_access_token_secrecy:
  all-traces
  "∀ token ClientID pkC #i.
    (Token_Issued( token, ClientID, pkC ) @ #i) ⇒
    ((¬(∃ #j. K( token ) @ #j)) ∨
     (∃ #l. LeakToken( token, pkC ) @ #l))"
/*
guarded formula characterizing all counter-examples:
"∃ token ClientID pkC #i.
  (Token_Issued( token, ClientID, pkC ) @ #i)
 ∧
  (∃ #j. (K( token ) @ #j)) ∧
  (∀ #l. (LeakToken( token, pkC ) @ #l) ⇒ ⊥)"
*/
simplify
solve( AuthzCode( authorization_code, ClientID, pk(x), iss
       ) ▶₁ #i )
  case AS_VerifyROPC_SendCode_ROPCStep5_6
  solve( !AS_Client_Tied_PublicKey( ~ClientID, pk(x), ~iss ) ▶₂ #i )
    case AS_VerifyJWTAndDPoPP_ToBackend_Step10
    solve( !AS_Identity( ~iss ) ▶₆ #i )
      case Setup_AS_Identity
