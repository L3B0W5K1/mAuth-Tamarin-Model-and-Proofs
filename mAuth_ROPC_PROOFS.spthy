rule (modulo E) Backend_ROPCStart_ToClient_ROPCStep1[role=Backend]:
   [ In_S( $AS, $Backend, <'ropc_start_as2b', ClientID, iss> ) ]
  -->
   [ Out_S( $Backend, $Client, <'ropc_start_b2c', ClientID, iss> ) ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Client_ROPCAuth_ROPCStep2_3[role=Client]:
   [
   In_S( $Backend, $Client, <'ropc_start_b2c', ClientID, iss> ),
   !Client_Expected_Iss( ClientID, iss ),
   !Client_Key( ClientID, skC, pkC ), !UserPassword( password ),
   Fr( ~DPoP_ROPC_Params )
   ]
  --[
  Client_Created_DPoP( pkC, ~DPoP_ROPC_Params, 'ropc' ),
  ROPC_Credentials_Used( ClientID, password ),
  ROPCAuth_Initiated( ClientID )
  ]->
   [
   Out_S( $Client, $Backend,
          <'ropc_auth_c2b', sign(<~DPoP_ROPC_Params, password>, skC), pkC, 
           ~DPoP_ROPC_Params, password, ClientID>
   )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) Backend_ROPCAuth_ToAS_ROPCStep4[role=Backend]:
   [
   In_S( $Client, $Backend,
         <'ropc_auth_c2b', dpopp, pkC, DPoP_Params, password, ClientID>
   )
   ]
  -->
   [
   Out_S( $Backend, $AS,
          <'ropc_auth_b2as', dpopp, pkC, DPoP_Params, password, ClientID>
   )
   ]

  // loop breaker: [0]
