theory mAuth_Scenario2_CIBA
begin

builtins: signing
heuristic: S

rule ChanOut_S:
    [ Out_S($A, $B, x) ]
    --[ ChanOut_S($A, $B, x) ]->
    [ Sec($A, $B, x) ]

rule ChanIn_S:
    [ Sec($A, $B, x) ]
    --[ ChanIn_S($A, $B, x) ]->
    [ In_S($A, $B, x) ]

// ============================================================================
// SETUP RULES
// ============================================================================

rule Setup_AS_Identity[role="AS"]:
    [ Fr(~iss) ]
    -->
    [ !AS_Identity(~iss) ]

rule Setup_Resource_Server[role="RS"]:
    [ Fr(~data) ]
    -->
    [ !RS_Resource(~data) ]

rule Setup_Backend_Identity[role="Backend"]:
    [ Fr(~backend_sk) ]
    --[ Secret_BackendKey(~backend_sk) ]->
    [ !Backend_Ltk(~backend_sk),
      !PkBackend(pk(~backend_sk)),
      !AS_Knows_Backend(pk(~backend_sk)) ]

// ============================================================================
// ATTESTATION CHALLENGE (Steps 2-3)
// ============================================================================

rule Client_AttestChallReq_ToBackend_Step2[role="Client"]:
    [ Fr(~ClientID) ]
    -->
    [ Out_S($Client, $Backend, <'step2_c2b', ~ClientID>),
    Client_KeygenSlot(~ClientID) ]

rule Backend_AttestChallReq_ToAS_Step2[role="Backend"]:
    [ In_S($Client, $Backend, <'step2_c2b', ClientID>) ]
    -->
    [ Out_S($Backend, $AS, <'step2_b2as', ClientID>) ]

rule AS_IssueChallenge_ToBackend_Step3[role="AS"]:
    [ In_S($Backend, $AS, <'step2_b2as', ClientID>),
      Fr(~nonce),
      !AS_Identity(iss) ]
    --[ AS_Issued_Nonce(~nonce),
        AS_Request_Accepted(<'challenge', ~nonce>) ]->
    [ Out_S($AS, $Backend, <'step3_as2b', ClientID, ~nonce, iss>),
      AS_Pending_Challenge_Nonce_Useable(ClientID, ~nonce, iss) ]

rule Backend_IssueChallenge_ToClient_Step3[role="Backend"]:
    [ In_S($AS, $Backend, <'step3_as2b', ClientID, nonce, iss>) ]
    -->
    [ Out_S($Backend, $Client, <'step3_b2c', ClientID, nonce, iss>) ]

// ============================================================================
// KEY GENERATION & ATTESTATION (Steps 4-7) 
// ============================================================================

rule Client_GenerateKey_ToClient_Step4[role="Client"]:
    [ In_S($Backend, $Client, <'step3_b2c', ClientID, nonce, iss>),
      Fr(~skC) ]
    --[ Secret_ClientKey(ClientID, ~skC),
        Client_Key_In_Hardware(pk(~skC)),
        Client_Learned_Iss(ClientID, iss) ]->
    [ Client_GenerateKey_ToClient_Step4(ClientID, nonce),
      !Client_Key(ClientID, ~skC, pk(~skC)),
      !Client_Expected_Iss(ClientID, iss) ]

rule Client_RequestAttestation_ToAA_Step5[role="Client"]:
    [ Client_GenerateKey_ToClient_Step4(ClientID, nonce),
      !Client_Key(ClientID, skC, pkC),
      Client_KeygenSlot(ClientID), 
      Fr(~Device_Info) ]
    --[ Client_Sent_Attestation_Request(ClientID, nonce, pkC) ]->
    [ Client_RequestAttestation_ToAA_Step5(<~Device_Info, nonce, pkC>),
      Client_AttestRequestPending_ToClient_Step5To8(ClientID, nonce, ~Device_Info),
      Client_ClientIDForKeygen_ToAA(ClientID) ]

rule Setup_AA_Enclave[role="AA"]:
    [ Client_ClientIDForKeygen_ToAA(ClientID),
      Fr(~aa_sk) ]
    --[ Secret_AAKey(~aa_sk) ]->
    [ !AA_Ltk(~aa_sk),
      !PkAA(ClientID, pk(~aa_sk))]

rule AA_SignAttestation_ToAA_Step6[role="AA"]:
    [ Client_RequestAttestation_ToAA_Step5(<Device_Info, nonce, pkC>),
      !AA_Ltk(aa_sk) ]
    --[ AA_Signed_Attestation(nonce, pkC),
        AA_NonceUsed(nonce) ]->
    [ AA_SignAttestation_ToAA_Step6(sign(<Device_Info, nonce, pkC>, aa_sk)) ]

rule AA_SendAttestation_ToClient_Step7[role="AA"]:
    [ AA_SignAttestation_ToAA_Step6(attestJWT) ]
    -->
    [ AA_SendAttestation_ToClient_Step7(attestJWT) ]

rule Client_ForwardPlatformAttest_ToBackend_Step7b[role="Client"]:
    [ AA_SendAttestation_ToClient_Step7(platformAttest),
      Client_AttestRequestPending_ToClient_Step5To8(ClientID, nonce, Device_Info),
      !Client_Key(ClientID, skC, pkC) ]
    -->
    [ Out_S($Client, $Backend, <'wrap_cat_c2b', ClientID, nonce, pkC, Device_Info, platformAttest>),
      Client_AwaitingCAT_ToClient(ClientID, nonce, Device_Info, platformAttest, pkC) ]

rule Backend_WrapCAT_ToClient_Step7c[role="Backend"]:
    [ In_S($Client, $Backend, <'wrap_cat_c2b', ClientID, nonce, pkC, Device_Info, platformAttest>),
      !Backend_Ltk(backend_sk) ]
    --[ Backend_Issued_CAT(ClientID, pkC, nonce) ]->
    [ Out_S($Backend, $Client,
         <'cat_response_b2c', ClientID,
           sign(<'client-attestation+jwt', ClientID, pkC, nonce, platformAttest>, backend_sk),
           platformAttest>) ]


// ============================================================================
// DPoP CREATION & AUTHORIZATION REQUEST (Steps 8-10)
// ============================================================================

rule Client_CreateDPoPP_ToClient_Step8[role="Client"]:
    [ In_S($Backend, $Client, <'cat_response_b2c', ClientID, clientAttestJWT, platformAttest>),
      Client_AwaitingCAT_ToClient(ClientID, nonce, Device_Info, platformAttest, pkC),
      !Client_Key(ClientID, skC, pkC),
      Fr(~DPoP_Params) ]
    --[ Client_Created_DPoP(pkC, ~DPoP_Params,'authz') ]->
    [ Client_DPoPAttestation_ToClient_Step8(ClientID, nonce, clientAttestJWT, platformAttest, Device_Info),
      Client_CreateDPoPP_ToClient_Step8(
          sign(<~DPoP_Params, nonce>, skC), pkC, ~DPoP_Params, nonce) ]

rule Client_SendAuthzReq_ToBackend_Step9[role="Client"]:
    [ Client_DPoPAttestation_ToClient_Step8(ClientID, nonce, clientAttestJWT, platformAttest, Device_Info),
      Client_CreateDPoPP_ToClient_Step8(dpopp, pkC, DPoP_Params, nonce) ]
    -->
    [ Out_S($Client, $Backend,
        <'step9_c2b', ClientID, nonce, Device_Info, platformAttest, clientAttestJWT,
         dpopp, pkC, DPoP_Params, pkC>) ]

rule Backend_SendAuthzReq_ToAS_Step9[role="Backend"]:
    [ In_S($Client, $Backend,
        <'step9_c2b', ClientID, nonce, Device_Info, platformAttest, clientAttestJWT,
         dpopp, pkC, DPoP_Params, dpop_jkt>) ]
    -->
    [ Out_S($Backend, $AS,
        <'step9_b2as', ClientID, nonce, Device_Info, platformAttest, clientAttestJWT,
         dpopp, pkC, DPoP_Params, dpop_jkt>) ]

rule AS_VerifyJWTAndDPoPP_ToBackend_Step10[role="AS"]:
    [ In_S($Backend, $AS, <'step9_b2as', ClientID, nonce, Device_Info, platformAttest, clientAttestJWT, dpopp, pkC, DPoP_Params, dpop_jkt>),
      AS_Pending_Challenge_Nonce_Useable(ClientID, nonce, iss),
      !PkAA(ClientID, pkAA),
      !AS_Knows_Backend(pkBackend),
      !AS_Identity(iss) ]
    --[ Eq(verify(platformAttest, <Device_Info, nonce, pkC>, pkAA), true), 
        Eq(verify(dpopp, <DPoP_Params,nonce>, pkC), true),
        Eq(verify(clientAttestJWT, <'client-attestation+jwt', ClientID, pkC, nonce, platformAttest>, pkBackend), true),
        Eq(dpop_jkt, pkC),
        AS_Request_Accepted(<'authorization', nonce>),
        AS_Accepted_Client_Key(ClientID, pkC),
        AS_Verified_CAT(ClientID, pkC),
        AS_Verified_PlatformAttest(ClientID, pkC),
        AS_Verified_dpop_jkt(ClientID, pkC),
        DPoP_Used(DPoP_Params),
        DPoP_Verified(DPoP_Params, pkC) ]->
    [ Out_S($AS, $Backend, <'ciba_start_as2b', ClientID, iss>),
      !AS_Client_Tied_PublicKey(ClientID, pkC, iss) ]

// ============================================================================
// CIBA AUTHENTICATION (Step 11)
// ============================================================================

rule Backend_CIBAStart_ToClient_CIBAStep1[role="Backend"]:
    [ In_S($AS, $Backend, <'ciba_start_as2b', ClientID, iss>) ]
    -->
    [ Out_S($Backend, $Client, <'ciba_start_b2c', ClientID, iss>) ]

rule Client_CIBAStart_ToBackend_CIBAStep2[role="Client"]:
    [ In_S($Backend, $Client, <'ciba_start_b2c', ClientID, iss>),
      !Client_Expected_Iss(ClientID, iss) ]
    -->
    [ Out_S($Client, $Backend, <'ciba_step2_c2b', ClientID>) ]

rule Backend_AuthReq_ToAS_CIBAStep2[role="Backend"]:
    [ In_S($Client, $Backend, <'ciba_step2_c2b', ClientID>) ]
    -->
    [ Out_S($Backend, $AS, <'ciba_step2_b2as', ClientID>) ]

rule AS_ACKSend_ToBackend_CIBAStep3[role="AS"]:
    [ In_S($Backend,$AS, <'ciba_step2_b2as', ClientID>),
      !AS_Client_Tied_PublicKey(ClientID, pkC, iss),
      Fr(~auth_req_id),
      !AS_Identity(iss) ]
    --[ AS_Request_Accepted(<'ciba_ack', ~auth_req_id>),
    ASOnly_AuthReq_ClientID_Action(~auth_req_id, ClientID) ]->
    [ Out_S($AS, $Backend, <'ciba_ack_as2b', ~auth_req_id, iss>),
      !AS_UserAuthPending_CIBA(~auth_req_id),
      !ASOnly_AuthReq_ClientID(~auth_req_id, ClientID),
      !ASOnly_AuthReq_ClientKey(~auth_req_id, pkC),
      !ASOnly_AuthReq_Iss(~auth_req_id, iss) ]

rule Backend_ACKSend_ToClient_CIBAStep3[role="Backend"]:
    [ In_S($AS,$Backend, <'ciba_ack_as2b', auth_req_id, iss>) ]
    -->
    [ Out_S($Backend, $Client, <'ciba_ack_b2c', auth_req_id, iss>) ]

rule Client_UserAuth_ToAuthMethod_PollStart_ToBackend_CIBAStep4[role="Client"]:
    [ In_S($Backend,$Client, <'ciba_ack_b2c', auth_req_id, iss>),
      !Client_Expected_Iss(ClientID, iss) ]
    -->
    [ Client_UserAuth_ToAuthMethod_CIBAStep4(auth_req_id),
      Out_S($Client, $Backend, <'ciba_poll_c2b', auth_req_id, ClientID>) ]

rule AuthMethod_UserAuth_ToAS_CIBAStep4[role="UserAuthMethod"]:
    [ Client_UserAuth_ToAuthMethod_CIBAStep4(auth_req_id) ]
    --[ UserAuth_Initiated(auth_req_id) ]->
    [ AuthMethod_UserAuth_ToAS_CIBAStep4(auth_req_id) ]

rule AS_UserAuthAccepted_ToAS_CIBAStep4[role="AS"]:
    [ AuthMethod_UserAuth_ToAS_CIBAStep4(auth_req_id),
      !AS_UserAuthPending_CIBA(auth_req_id),
      !ASOnly_AuthReq_ClientID(auth_req_id, ClientID),
      !ASOnly_AuthReq_ClientKey(auth_req_id, pkC),
      !ASOnly_AuthReq_Iss(auth_req_id, iss),
      Fr(~authorization_code) ]
    --[ AS_UserAuthAccepted(auth_req_id),
        CIBA_AuthEvent_Bound(auth_req_id, ~authorization_code),
        AS_Request_Accepted(<'ciba_user_auth', auth_req_id>),
        AS_Auth_Completed(ClientID),
        AuthzCode_Issued(~authorization_code, ClientID, pkC, iss) ]->
    [ AS_UserAuthAccepted_ToAS_CIBAStep4(~authorization_code, auth_req_id),
      AuthzCode(~authorization_code, ClientID, pkC, iss) ]

rule Backend_Poll_ToAS_Step5[role="Backend"]:
    [ In_S($Client, $Backend, <'ciba_poll_c2b', auth_req_id, ClientID>) ]
    --[ CIBA_Poll_Sent(auth_req_id) ]->
    [ Out_S($Backend, $AS, <'ciba_poll_b2as', auth_req_id>) ]

rule AS_PollAnsPending_ToBackend_CIBAStep5[role="AS"]:
    [ In_S($Backend, $AS, <'ciba_poll_b2as', auth_req_id>),
      !AS_UserAuthPending_CIBA(auth_req_id),
      !ASOnly_AuthReq_ClientID(auth_req_id, ClientID) ]
    --[ AS_Request_Accepted(<'poll_pending', auth_req_id>) ]->
    []

rule AS_PollAnsAuthorized_ToBackend_CIBAStep5[role="AS"]:
    [ In_S($Backend, $AS, <'ciba_poll_b2as', auth_req_id>),
      !AS_UserAuthPending_CIBA(auth_req_id),
      AS_UserAuthAccepted_ToAS_CIBAStep4(authorization_code, auth_req_id),
      !ASOnly_AuthReq_ClientID(auth_req_id, ClientID) ]
    --[ AS_Request_Accepted(<'poll_authorized', auth_req_id>),
        CIBA_Code_Issued(auth_req_id) ]->
    [ Out_S($AS, $Backend, <'auth_completed_as2b', ClientID, authorization_code>) ]

// ============================================================================
// TOKEN EXCHANGE & RESOURCE ACCESS (Steps 12-19)
// ============================================================================


rule Backend_RequestDPoP_ForTokenExchange[role="Backend"]:
    [ In_S($AS, $Backend, <'auth_completed_as2b', ClientID, authorization_code>) ]
    -->
    [ Out_S($Backend, $Client, <'dpop_needed_for_token_b2c', ClientID>),
      Backend_PendingTokenExchange(ClientID, authorization_code) ]

rule Client_CreateDPoP_ForTokenExchange[role="Client"]:
    [ In_S($Backend, $Client, <'dpop_needed_for_token_b2c', ClientID>),
      !Client_Key(ClientID, skC, pkC),
      Fr(~DPoP_Params_TE) ]
    --[ Client_Created_DPoP(pkC, ~DPoP_Params_TE,'token_te') ]->
    [ Out_S($Client, $Backend, <'dpop_for_token_c2b',
            sign(<~DPoP_Params_TE,'token_endpoint'>, skC), pkC, ~DPoP_Params_TE, ClientID>) ]

rule Backend_TokenRequest_ToAS_Step12[role="Backend"]:
    [ In_S($Client, $Backend, <'dpop_for_token_c2b', dpopp_te, pkC, DPoP_Params_TE, ClientID>),
      Backend_PendingTokenExchange(ClientID, authorization_code) ]
    -->
    [ Out_S($Backend, $AS, <'token_req_b2as', ClientID, authorization_code,
            dpopp_te, pkC, DPoP_Params_TE>) ]

rule AS_TokenAns_ToBackend_Step13[role="AS"]:
    [ In_S($Backend, $AS, <'token_req_b2as', ClientID, authorization_code,
            dpopp_te, pkC, DPoP_Params_TE>),
      AuthzCode(authorization_code, ClientID, pkC, iss),
      !AS_Client_Tied_PublicKey(ClientID, pkC, iss),
      Fr(~constrained_access_token),
      Fr(~DPoP_reference_token),
      Fr(~refresh_token),
      !AS_Identity(iss) ]
    --[ Eq(verify(dpopp_te, <DPoP_Params_TE,'token_endpoint'>, pkC), true),
        DPoP_Used(DPoP_Params_TE),
        DPoP_Verified(DPoP_Params_TE, pkC),
        AS_Request_Accepted(<'token_exchange', authorization_code>),
        AuthzCode_Redeemed(authorization_code, ClientID, pkC),
        Token_Issued(~constrained_access_token, ClientID, pkC),
        RefToken_Issued(~DPoP_reference_token, ClientID, pkC),
        RefreshToken_Issued(~refresh_token, ClientID, pkC),
        Token_Issued_By_Iss(ClientID, iss) ]->
    [ !ConstrainedAccess(~constrained_access_token, pkC),
      !ConstrainedReference(~DPoP_reference_token, pkC, iss),
      !ConstrainedRefresh(~refresh_token, pkC),
      Out_S($AS, $Backend, <'token_resp_as2b', ClientID, ~DPoP_reference_token,
             ~constrained_access_token, pkC, iss, ~refresh_token>) ]

rule Backend_SendReferenceToken_ToClient_Step14[role="Backend"]:
    [ In_S($AS, $Backend, <'token_resp_as2b', ClientID, DPoP_reference_token,
            constrained_access_token, pkC, iss, refresh_token>) ]
    -->
    [ Out_S($Backend, $Client, <'ref_token_b2c', ClientID, DPoP_reference_token, iss>),
      Backend_AccessTokenHeld(DPoP_reference_token, constrained_access_token, pkC, ClientID),
      Backend_RefreshTokenHeld(refresh_token, pkC, ClientID) ]

rule Client_GenerateDPoP_Step15_SendDPoP_ToBackend_Step16[role="Client"]:
    [ In_S($Backend, $Client, <'ref_token_b2c', ClientID, DPoP_reference_token, iss>),
      !Client_Key(ClientID, skC, pkC),
      !Client_Expected_Iss(ClientID, iss),
      Fr(~DPoP_Params2) ]
    --[ Client_Verified_Iss(ClientID, iss),
        Client_Created_DPoP(pkC, ~DPoP_Params2,'resource') ]->
    [ Out_S($Client, $Backend, <'dpop_resource_c2b',
            sign(<~DPoP_Params2, DPoP_reference_token>, skC),
            pkC, ~DPoP_Params2, DPoP_reference_token>),
      Client_CanRefresh(ClientID) ]

rule Backend_ResourceRequest_ToRS_Step17[role="Backend"]:
    [ In_S($Client,$Backend, <'dpop_resource_c2b', dpopp, pkC, DPoP_Params2, DPoP_reference_token>),
      Backend_AccessTokenHeld(DPoP_reference_token, constrained_access_token, pkC, ClientID) ]
    -->
    [ Out_S($Backend, $RS, <'rs_verify_b2rs', constrained_access_token, dpopp, pkC,
            DPoP_Params2, DPoP_reference_token, ClientID>) ]

rule RS_ForwardIntrospection_ToAS[role="RS API"]:
    [ In_S($Backend, $RS, <'rs_verify_b2rs', constrained_access_token, dpopp, pkC,
           DPoP_Params2, DPoP_reference_token, ClientID>)]
    -->
    [ Out_S($RS, $AS, <'introspect', constrained_access_token, dpopp, pkC,
            DPoP_Params2, DPoP_reference_token, ClientID>) ,
            RS_Client_Tied_Access(ClientID,constrained_access_token)]

rule AS_VerifyDPoPPAndTokens_Step18[role="AS"]:
    [ In_S($RS, $AS, <'introspect', constrained_access_token, dpopp, pkC,
           DPoP_Params2, DPoP_reference_token, ClientID>),
      !ConstrainedAccess(constrained_access_token, pkC),
      !ConstrainedReference(DPoP_reference_token, pkC, iss),
      !AS_Client_Tied_PublicKey(ClientID, pkC, iss) ,
      !AS_Identity(iss) ]
    --[ Eq(verify(dpopp, <DPoP_Params2, DPoP_reference_token>, pkC), true),
        DPoP_Used(DPoP_Params2),
        DPoP_Verified(DPoP_Params2, pkC),
        AS_Request_Accepted(<'resource_access', DPoP_Params2>),
        Token_Used_For_Access(constrained_access_token, ClientID, pkC) ]->
    [ Out_S($AS, $RS, <'verified', ClientID, constrained_access_token>) ]

rule RS_SendResource_Step19[role="RS API"]:
    [ In_S($AS, $RS, <'verified', ClientID, constrained_access_token>),
      !RS_Resource(data),
      RS_Client_Tied_Access(ClientID, constrained_access_token) ]
    --[ RS_Sent_Resource(data, ClientID, constrained_access_token),
        RS_Access_Granted(data, ClientID) ]->
    [ Out_S($RS, $Client, <'resource_sent', data, ClientID>) ]

rule Client_Received_Data[role="Client"]:
   [In_S($RS,$Client,<'resource_sent',data,ClientID>)] 
   --[Client_Recourse_Received(data,ClientID)]->
   []


// ============================================================================
// REFRESH TOKEN EXCHANGE
// ============================================================================

rule Client_RequestRefresh[role="Client"]:
    [ Client_CanRefresh(ClientID),
      !Client_Key(ClientID, skC, pkC),
      Fr(~DPoP_Params_Refresh) ]
    --[ Client_Created_DPoP(pkC, ~DPoP_Params_Refresh,'refresh'),
        Client_Requested_Refresh(ClientID) ]->
    [ Out_S($Client, $Backend, <'refresh_req_c2b',
            sign(<~DPoP_Params_Refresh, 'refresh'>, skC),
            pkC, ~DPoP_Params_Refresh, ClientID>) ]

rule Backend_RefreshRequest_ToAS[role="Backend"]:
    [ In_S($Client, $Backend, <'refresh_req_c2b', dpopp, pkC, DPoP_Params_R, ClientID>),
      Backend_RefreshTokenHeld(refresh_token, pkC, ClientID) ]
    -->
    [ Out_S($Backend, $AS, <'refresh_req_b2as', refresh_token, dpopp, pkC, DPoP_Params_R, ClientID>) ]

rule AS_VerifyRefresh_IssueToken[role="AS"]:
    [ In_S($Backend, $AS, <'refresh_req_b2as', refresh_token, dpopp, pkC, DPoP_Params_R, ClientID>),
      !ConstrainedRefresh(refresh_token, pkC),
      !AS_Client_Tied_PublicKey(ClientID, pkC, iss),
      !AS_Identity(iss)  ]
    --[ Eq(verify(dpopp, <DPoP_Params_R,'refresh'>, pkC), true),
        DPoP_Used(DPoP_Params_R),
        DPoP_Verified(DPoP_Params_R, pkC),
        AS_Request_Accepted(<'refresh', DPoP_Params_R>),
        RefreshToken_Used(refresh_token, ClientID, pkC) ]->
    [ AS_RefreshCompleted(ClientID) ]

// ============================================================================
// LEAK / ATTACKER EVENTS
// ============================================================================

rule Leak_Access_Token:
    [ !ConstrainedAccess(token, pkC) ]
    --[ LeakToken(token, pkC) ]->
    [ Out(token) ]

rule Leak_Reference_Token:
    [ !ConstrainedReference(ref_token, pkC, iss) ]
    --[ LeakRefToken(ref_token, pkC) ]->
    [ Out(ref_token) ]

rule Leak_Refresh_Token:
    [ !ConstrainedRefresh(refresh_token, pkC) ]
    --[ LeakRefreshToken(refresh_token, pkC) ]->
    [ Out(refresh_token) ]

rule Reveal_AA_Key:
    [ !AA_Ltk(aa_sk) ]
    --[ RevealAA(aa_sk) ]->
    [ Out(aa_sk) ]

rule Reveal_Client_Key:
    [ !Client_Key(ClientID, skC, pkC) ]
    --[ RevealClientKey(ClientID, skC) ]->
    [ Out(skC) ]

rule Reveal_Backend_Key:
    [ !Backend_Ltk(backend_sk) ]
    --[ RevealBackend(backend_sk) ]->
    [ Out(backend_sk) ]

// ============================================================================
// RESTRICTIONS
// ============================================================================

restriction Equality:
    "All x y #i. Eq(x,y) @ #i ==> x = y"

restriction unique_dpopp:
    "All params #i #j.
       DPoP_Used(params) @ #i & DPoP_Used(params) @ #j
       ==> #i = #j"

restriction ciba_single_code_issuance:
    "All id #i #j.
       CIBA_Code_Issued(id) @ #i & CIBA_Code_Issued(id) @ #j
       ==> #i = #j"

restriction no_replay:
    "All id #i #j.
       AS_Request_Accepted(id) @ #i & AS_Request_Accepted(id) @ #j
       ==> #i = #j"

restriction unique_attestation_per_nonce:
    "All nonce pkC1 pkC2 #i #j.
       AA_Signed_Attestation(nonce, pkC1) @ #i
       & AA_Signed_Attestation(nonce, pkC2) @ #j
       ==> #i = #j"  


lemma typing [sources]:
  " (All t cid pk #i #j.
        Token_Issued(t, cid, pk) @ #j & !KU(t) @ #i
        ==> (Ex #l. LeakToken(t, pk) @ #l & #l < #i))
  & (All t cid pk #i #j.
        RefToken_Issued(t, cid, pk) @ #j & !KU(t) @ #i
        ==> (Ex #l. LeakRefToken(t, pk) @ #l & #l < #i))
  & (All t cid pk #i #j.
        RefreshToken_Issued(t, cid, pk) @ #j & !KU(t) @ #i
        ==> (Ex #l. LeakRefreshToken(t, pk) @ #l & #l < #i))
  & (All c cid pk iss #i #j.
        AuthzCode_Issued(c, cid, pk, iss) @ #j & !KU(c) @ #i
        ==> F)
  "

lemma token_implies_code [reuse]:
  "All t cid pk #i. Token_Issued(t, cid, pk) @ #i
   ==> (Ex c iss #j. AuthzCode_Issued(c, cid, pk, iss) @ #j & #j < #i)"

lemma code_implies_accept [reuse]:
  "All c cid pk iss #i. AuthzCode_Issued(c, cid, pk, iss) @ #i
   ==> (Ex #j. AS_Accepted_Client_Key(cid, pk) @ #j & #j < #i)"

lemma access_implies_issued [reuse, use_induction]:
  "All t cid pk #i. Token_Used_For_Access(t, cid, pk) @ #i
   ==> (Ex #j. Token_Issued(t, cid, pk) @ #j & #j < #i)"

lemma refresh_used_implies_issued [reuse]:
  "All t cid pk #i. RefreshToken_Used(t, cid, pk) @ #i
   ==> (Ex #j. RefreshToken_Issued(t, cid, pk) @ #j & #j < #i)"

lemma accept_unique_pkC [reuse, use_induction]:
  "All cid pk1 pk2 #i #j.
      AS_Accepted_Client_Key(cid, pk1) @ #i
    & AS_Accepted_Client_Key(cid, pk2) @ #j
    ==> pk1 = pk2"

lemma client_iss_unique [reuse, use_induction]:
  "All cid iss1 iss2 #i #j.
      Client_Learned_Iss(cid, iss1) @ #i
    & Client_Learned_Iss(cid, iss2) @ #j
    ==> iss1 = iss2 & #i = #j"
/*
lemma accept_implies_hardware [reuse]:
  all-traces
  "All cid pkC #i. AS_Accepted_Client_Key(cid, pkC) @ #i
   ==> (Ex #j. Client_Key_In_Hardware(pkC) @ #j & #j < #i)
       | (Ex aa_sk #r. RevealAA(aa_sk) @ #r)
       | (Ex skC #r. RevealClientKey(cid, skC) @ #r)"
*/
//unique

lemma L_unique_dpopp_proof:
    all-traces
    "All params #i #j.
       DPoP_Used(params) @ #i & DPoP_Used(params) @ #j
       ==> #i = #j"
       
lemma L_unique_attestation_proof:
    all-traces
    "All nonce pkC1 pkC2 #i #j.
       AA_Signed_Attestation(nonce, pkC1) @ #i
       & AA_Signed_Attestation(nonce, pkC2) @ #j
       ==> #i = #j & pkC1 = pkC2"

