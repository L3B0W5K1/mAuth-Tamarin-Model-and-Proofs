lemma SANITY_full_chain[hide_lemma=R2_dpop_requires_creation,
   hide_lemma=B1_attestation_unforgeable,
   hide_lemma=B2_as_requires_attestation,
   hide_lemma=B3_token_implies_attestation,
   hide_lemma=accept_implies_hardware,
   hide_lemma=I1_token_requires_hardware_key,
   hide_lemma=accept_unique_pkC,
   hide_lemma=client_iss_unique,
   hide_lemma=token_implies_code,
   hide_lemma=code_implies_accept,
   hide_lemma=access_implies_issued,
   hide_lemma=refresh_used_implies_issued]:
    exists-trace
    "Ex data ClientID nonce pkC code token auth_req_id iss
        #t1 #t2 #t3 #t4 #t5 #t6 #t7 #t8 #t9 #t10 #t11.
       AS_Issued_Nonce(nonce)                                @ #t1
     & Client_Sent_Attestation_Request(ClientID, nonce, pkC) @ #t2
     & AA_Signed_Attestation(nonce, pkC)                     @ #t3
     & Backend_Issued_CAT(ClientID, pkC, nonce)              @ #t4
     & AS_Accepted_Client_Key(ClientID, pkC)                 @ #t5
     & UserAuth_Initiated(auth_req_id)                       @ #t6
     & AS_UserAuthAccepted(auth_req_id)                      @ #t7
     & AuthzCode_Issued(code, ClientID, pkC, iss)            @ #t7   
     & CIBA_Code_Issued(auth_req_id)                         @ #t8
     & Token_Issued(token, ClientID, pkC)                    @ #t9
     & Token_Used_For_Access(token, ClientID, pkC)           @ #t10
     & Client_Recourse_Received(data, ClientID)              @ #t11
     & #t1 < #t2 & #t2 < #t3 & #t3 < #t4 & #t4 < #t5
     & #t5 < #t6 & #t6 < #t7 & #t7 < #t8 & #t8 < #t9
     & #t9 < #t10 & #t10 < #t11"

// ============================================================================
// S: SECRET KEY SECRECY
// ============================================================================

lemma S1_client_key_secrecy:
    all-traces
    "All ClientID k #i. Secret_ClientKey(ClientID, k) @ #i
     ==> not (Ex #j. K(k) @ #j)
         | (Ex #r. RevealClientKey(ClientID, k) @ #r)"

lemma S2_access_token_secrecy:
    all-traces
    "All token ClientID pkC #i. Token_Issued(token, ClientID, pkC) @ #i
     ==> not (Ex #j. K(token) @ #j)
         | (Ex #l. LeakToken(token, pkC) @ #l)"

lemma S3_reference_token_secrecy:
    all-traces
    "All token ClientID pkC #i. RefToken_Issued(token, ClientID, pkC) @ #i
     ==> not (Ex #j. K(token) @ #j)
         | (Ex #l. LeakRefToken(token, pkC) @ #l)"

lemma S4_aa_key_secrecy:
    all-traces
    "All k #i. Secret_AAKey(k) @ #i
     ==> not (Ex #j. K(k) @ #j)
         | (Ex #r. RevealAA(k) @ #r)"

lemma S5_refresh_token_secrecy:
    all-traces
    "All token ClientID pkC #i. RefreshToken_Issued(token, ClientID, pkC) @ #i
     ==> not (Ex #j. K(token) @ #j)
         | (Ex #l. LeakRefreshToken(token, pkC) @ #l)"

lemma S6_backend_key_secrecy:
    all-traces
    "All k #i. Secret_BackendKey(k) @ #i
     ==> not (Ex #j. K(k) @ #j)
         | (Ex #r. RevealBackend(k) @ #r)"

// ============================================================================
// Z: AUTHORIZATION CORRECTNESS
// ============================================================================


lemma Z1_code_after_attestation:
    all-traces
    "All code ClientID pkC iss #i. AuthzCode_Issued(code, ClientID, pkC, iss) @ #i
     ==> (Ex nonce #j #k. 
       AS_Issued_Nonce(nonce) @ #j 
       & AA_Signed_Attestation(nonce, pkC) @ #k & #j < #k & #k < #i)
         | (Ex aa_sk #r. RevealAA(aa_sk) @ #r)"

lemma Z2_no_double_redeem:
    all-traces
    "not (Ex code ClientID1 ClientID2 pkC1 pkC2 #i #j.
            AuthzCode_Redeemed(code, ClientID1, pkC1) @ #i
            & AuthzCode_Redeemed(code, ClientID2, pkC2) @ #j
            & not (#i = #j))"

lemma Z3_no_auth_code_substitution:
    all-traces
    "All code ClientID1 ClientID2 pkC1 pkC2 iss #i #j.
       AuthzCode_Issued(code, ClientID1, pkC1, iss) @ #i
       & AuthzCode_Redeemed(code, ClientID2, pkC2) @ #j
       ==> ClientID1 = ClientID2 & pkC1 = pkC2"


lemma Z4_code_unique_issuance: 
    all-traces
    "All code ClientID1 ClientID2 pkC1 pkC2 iss1 iss2 #i #j.
       AuthzCode_Issued(code, ClientID1, pkC1, iss1) @ #i
       & AuthzCode_Issued(code, ClientID2, pkC2, iss2) @ #j
       ==> #i = #j & ClientID1 = ClientID2 & pkC1 = pkC2 & iss1 = iss2"

// ============================================================================
// T: TOKEN BINDING / PROOF-OF-POSSESSION
// ============================================================================

lemma T1_stolen_token_unusable:
    all-traces
    "All token pkC ClientID #i #j.
       LeakToken(token, pkC) @ #i
       & Token_Used_For_Access(token, ClientID, pkC) @ #j
       ==> (Ex params ctx #k #l.
              Client_Created_DPoP(pkC, params,ctx) @ #k
              & DPoP_Verified(params, pkC) @ #l
              & #k < #l & #l < #j)
           | (Ex skC #r. RevealClientKey(ClientID, skC) @ #r)"

lemma T2_token_access_requires_pop:
    all-traces
    "All token ClientID pkC #i. Token_Used_For_Access(token, ClientID, pkC) @ #i
     ==> (Ex params #j #k.
            DPoP_Verified(params, pkC) @ #j
            & AS_Accepted_Client_Key(ClientID, pkC) @ #k
            & (#k < #j | #k = #j)
            &  #j < #i)
         | (Ex skC #r. RevealClientKey(ClientID, skC) @ #r)"

lemma T3_no_token_identity_crossing:
    all-traces
    "All token ClientID1 ClientID2 pkC1 pkC2 #i #j.
       Token_Issued(token, ClientID1, pkC1) @ #i
       & Token_Used_For_Access(token, ClientID2, pkC2) @ #j
       ==> ClientID1 = ClientID2 & pkC1 = pkC2"

lemma T4_stolen_refresh_token_unusable:
    all-traces
    "All token pkC ClientID #i #j.
       LeakRefreshToken(token, pkC) @ #i
       & RefreshToken_Used(token, ClientID, pkC) @ #j
       ==> (Ex params ctx #k. Client_Created_DPoP(pkC, params,ctx) @ #k & #k < #j)
           | (Ex skC #k. RevealClientKey(ClientID, skC) @ #k)"

lemma T5_stolen_refresh_needs_dpop:
    all-traces
    "All token pkC ClientID #i #j.
       LeakRefreshToken(token, pkC) @ #i
       & RefreshToken_Used(token, ClientID, pkC) @ #j
       ==> (Ex params ctx #k #l.
              Client_Created_DPoP(pkC, params, ctx) @ #k
              & DPoP_Verified(params, pkC) @ #l
              & #k < #l & #l = #j)
           | (Ex skC #r. RevealClientKey(ClientID, skC) @ #r)"


// ============================================================================
// R: REPLAY RESISTANCE AND FRESHNESS
// ============================================================================

lemma R1_dpop_requires_creation: 
    all-traces
    "All params pkC #i. DPoP_Verified(params, pkC) @ #i
     ==> (Ex ctx #j. Client_Created_DPoP(pkC, params, ctx) @ #j & #j < #i)
         | (Ex ClientID skC #r. RevealClientKey(ClientID, skC) @ #r)"

// ============================================================================
// B: ATTESTATION BINDING
// ============================================================================

lemma B1_attestation_unforgeable[reuse]: 
    all-traces
    "All nonce pkC #i. AA_Signed_Attestation(nonce, pkC) @ #i
     ==> (Ex ClientID #j. Client_Sent_Attestation_Request(ClientID, nonce, pkC) @ #j & #j < #i)
         | (Ex aa_sk #r. RevealAA(aa_sk) @ #r)"

lemma B2_as_requires_attestation[reuse]:
    all-traces
    "All ClientID pkC #i. AS_Accepted_Client_Key(ClientID, pkC) @ #i
     ==> (Ex nonce #j. AA_Signed_Attestation(nonce, pkC) @ #j & #j < #i)
         | (Ex aa_sk #r. RevealAA(aa_sk) @ #r)"

lemma B3_token_implies_attestation[reuse]:
    all-traces
    "All token ClientID pkC #i. Token_Issued(token, ClientID, pkC) @ #i
     ==> (Ex nonce #j #k.
       AA_Signed_Attestation(nonce, pkC) @ #j
       & AS_Accepted_Client_Key(ClientID, pkC) @ #k
       & #j < #k & #k < #i)
        | (Ex aa_sk #r. RevealAA(aa_sk) @ #r)"


lemma B4_attestation_key_binding:
    all-traces
    "All ClientID1 ClientID2 pkC1 pkC2 nonce #i #j #k1 #k2.
       AS_Accepted_Client_Key(ClientID1, pkC1) @ #i
       & AS_Accepted_Client_Key(ClientID2, pkC2) @ #j
       & AA_Signed_Attestation(nonce, pkC1) @ #k1
       & AA_Signed_Attestation(nonce, pkC2) @ #k2
       ==> pkC1 = pkC2"

lemma B5_attestation_nonce_single_use:
    all-traces
    "All nonce #i #j.
       AA_NonceUsed(nonce) @ #i & AA_NonceUsed(nonce) @ #j
       ==> #i = #j"


lemma B6_cat_unforgeable:
    all-traces
    "All ClientID pkC #i.
       AS_Verified_CAT(ClientID, pkC) @ #i
       ==> (Ex nonce #j. Backend_Issued_CAT(ClientID, pkC, nonce) @ #j & #j < #i)
           | (Ex backend_sk #r. RevealBackend(backend_sk) @ #r)"

lemma B7_dpop_jkt_matches_instance_key: 
    all-traces
    "All ClientID pkC #i.
       AS_Verified_dpop_jkt(ClientID, pkC) @ #i
       ==> (Ex nonce #j.
              Client_Sent_Attestation_Request(ClientID, nonce, pkC) @ #j
              & #j < #i)
           | (Ex skC #r. RevealClientKey(ClientID, skC) @ #r)"

// ============================================================================
// K: Key contineuity
// ============================================================================

lemma K1_key_continuity_attestation_to_token:
    all-traces
    "All ClientID pkC_accept token pkC_token #i #j.
       AS_Accepted_Client_Key(ClientID, pkC_accept) @ #i
       & Token_Issued(token, ClientID, pkC_token) @ #j
       & #i < #j
       ==> pkC_accept = pkC_token
           | (Ex skC #r. RevealClientKey(ClientID, skC) @ #r)"

lemma K2_key_continuity_token_to_access:
    all-traces
    "All token ClientID pkC1 pkC2 #i #j.
       Token_Issued(token, ClientID, pkC1) @ #i
       & Token_Used_For_Access(token, ClientID, pkC2) @ #j
       ==> pkC1 = pkC2"


lemma K3_dpop_key_matches_accepted:
    all-traces
    "All params pkC_dpop ClientID pkC_accept token #i #j #k.
       DPoP_Verified(params, pkC_dpop) @ #i
       & AS_Accepted_Client_Key(ClientID, pkC_accept) @ #j
       & Token_Used_For_Access(token, ClientID, pkC_dpop) @ #k
       & #j < #i & #i = #k
       ==> pkC_dpop = pkC_accept
           | (Ex skC #r. RevealClientKey(ClientID, skC) @ #r)"


// ============================================================================
// I: CLIENT / DEVICE IDENTITY BINDING
// ============================================================================

lemma I1_token_requires_hardware_key [reuse]:
  all-traces
  "All token ClientID pkC #i.
    Token_Issued(token, ClientID, pkC) @ #i
    ==>
      (Ex #j #k.
         Client_Key_In_Hardware(pkC) @ #j
         & AS_Accepted_Client_Key(ClientID, pkC) @ #k
         & #j < #k & #k < #i)
      | (Ex skC #r. RevealClientKey(ClientID, skC) @ #r)
      | (Ex aa_sk #r. RevealAA(aa_sk) @ #r)"    

lemma I2_access_requires_hardware_key:
    all-traces
    "All token ClientID pkC #i #j.
       Token_Used_For_Access( token, ClientID, pkC ) @ #i
       & Token_Issued( token, ClientID, pkC ) @ #j
       & #j < #i
       ==> (Ex #k #l.
              Client_Key_In_Hardware( pkC ) @ #k
              & AS_Accepted_Client_Key( ClientID, pkC ) @ #l
              & #k < #l & #l < #j)
           | (Ex skC #r. RevealClientKey( ClientID, skC ) @ #r)
           | (Ex aa_sk #r. RevealAA( aa_sk ) @ #r)"      

// ============================================================================
// E: END-TO-END
// ============================================================================

lemma E1_token_requires_authentication:
    all-traces
    "All token ClientID pkC #i. Token_Issued(token, ClientID, pkC) @ #i
     ==> (Ex #j. AS_Auth_Completed(ClientID) @ #j & #j < #i)"

lemma E2_resource_matches_issued_token: 
    all-traces
    "All data ClientID #i.
       Client_Recourse_Received(data, ClientID) @ #i
       ==> (Ex token pkC #j #k.
              RS_Sent_Resource(data, ClientID, token) @ #j
              & Token_Issued(token, ClientID, pkC) @ #k
              & #k < #j & #j < #i)"


lemma E3_resource_requires_fresh_dpop[hide_lemma=B1_attestation_unforgeable, 
   hide_lemma=B2_as_requires_attestation,
   hide_lemma=B3_token_implies_attestation,
   hide_lemma=accept_implies_hardware,
   hide_lemma=I1_token_requires_hardware_key]:
    all-traces
    "All data ClientID #i. Client_Recourse_Received(data, ClientID) @ #i
     ==> (Ex pkC ctx params #j #k. 
            Client_Created_DPoP(pkC, params, ctx) @ #j
            & DPoP_Verified(params, pkC) @ #k
            & #j < #k & #k < #i
            & (Ex #l. AS_Accepted_Client_Key(ClientID, pkC) @ #l))
         | (Ex skC #r. RevealClientKey(ClientID, skC) @ #r)"

lemma E4_refresh_requires_issuance: 
    all-traces
    "All token ClientID pkC #i.
       RefreshToken_Used(token, ClientID, pkC) @ #i
       ==> (Ex #j.
              RefreshToken_Issued(token, ClientID, pkC) @ #j
              & #j < #i)"


// ============================================================================
// ISS: MIX-UP PREVENTION
// ============================================================================

lemma ISS1_consistency[hide_lemma=R2_dpop_requires_creation,
   hide_lemma=B1_attestation_unforgeable,
   hide_lemma=B2_as_requires_attestation,
   hide_lemma=B3_token_implies_attestation,
   hide_lemma=accept_implies_hardware,
   hide_lemma=I1_token_requires_hardware_key]:
    all-traces
    "All ClientID iss #i.
       Client_Verified_Iss(ClientID, iss) @ #i
       ==> (Ex #j. Client_Learned_Iss(ClientID, iss) @ #j & #j < #i)"


lemma ISS2_no_mix_up[hide_lemma=R2_dpop_requires_creation, 
   hide_lemma=B1_attestation_unforgeable,
   hide_lemma=B2_as_requires_attestation,
   hide_lemma=B3_token_implies_attestation,
   hide_lemma=accept_implies_hardware,
   hide_lemma=I1_token_requires_hardware_key]:
    all-traces
    "All code ClientID pkC iss1 iss2 #i #j.
       AuthzCode_Issued(code, ClientID, pkC, iss1) @ #i
       & AuthzCode_Redeemed(code, ClientID, pkC) @ #j
       & Token_Issued_By_Iss(ClientID, iss2) @ #j
       ==> iss1 = iss2"


lemma ISS3_token_origin[hide_lemma=R2_dpop_requires_creation,
   hide_lemma=B1_attestation_unforgeable,
   hide_lemma=B2_as_requires_attestation,
   hide_lemma=B3_token_implies_attestation,
   hide_lemma=accept_implies_hardware,
   hide_lemma=I1_token_requires_hardware_key]:
    all-traces
    "All ClientID iss #i. Token_Issued_By_Iss(ClientID, iss) @ #i
     ==> (Ex code pkC #j. AuthzCode_Issued(code, ClientID, pkC, iss) @ #j & #j < #i)"

lemma ISS4_client_rejects_wrong_iss[hide_lemma=R2_dpop_requires_creation,
   hide_lemma=B1_attestation_unforgeable,
   hide_lemma=B2_as_requires_attestation,
   hide_lemma=B3_token_implies_attestation,
   hide_lemma=accept_implies_hardware,
   hide_lemma=I1_token_requires_hardware_key]:
    all-traces
    "All ClientID iss_learned iss_verified #i #j.
       Client_Learned_Iss(ClientID, iss_learned) @ #i
       & Client_Verified_Iss(ClientID, iss_verified) @ #j
       & #i < #j
       ==> iss_learned = iss_verified"
       
lemma ISS5_refresh_preserves_iss[hide_lemma=R2_dpop_requires_creation,
   hide_lemma=B1_attestation_unforgeable,
   hide_lemma=B2_as_requires_attestation,
   hide_lemma=B3_token_implies_attestation,
   hide_lemma=accept_implies_hardware,
   hide_lemma=I1_token_requires_hardware_key]:
    all-traces
    "All ClientID iss_orig token pkC #i #j.
       Token_Issued_By_Iss(ClientID, iss_orig) @ #i
       & RefreshToken_Used(token, ClientID, pkC) @ #j
       & #i < #j
       ==> (Ex code #k.
              AuthzCode_Issued(code, ClientID, pkC, iss_orig) @ #k
              & #k < #j)"

// ============================================================================
// FLOW
// ============================================================================
lemma F1_resource_access_requires_token_exchange:
    all-traces
    "All params #i.
       AS_Request_Accepted(<'resource_access', params>) @ #i
       ==> (Ex code #j.
              AS_Request_Accepted(<'token_exchange', code>) @ #j
              & #j < #i)"

lemma F2_token_exchange_requires_authorization:
    all-traces
    "All code #i.
       AS_Request_Accepted(<'token_exchange', code>) @ #i
       ==> (Ex nonce #j.
              AS_Request_Accepted(<'authorization', nonce>) @ #j
              & #j < #i)"

lemma F3_authorization_requires_challenge:
    all-traces
    "All nonce #i.
       AS_Request_Accepted(<'authorization', nonce>) @ #i
       ==> (Ex #j.
              AS_Request_Accepted(<'challenge', nonce>) @ #j
              & #j < #i)"

// ============================================================================
// CIBA-SPECIFIC
// ============================================================================

lemma CIBA1_authcode_after_user_auth:
    all-traces
    "All code ClientID pkC iss #i. AuthzCode_Issued(code, ClientID, pkC, iss) @ #i
     ==> (Ex auth_req_id #j. 
            UserAuth_Initiated(auth_req_id) @ #j 
            & CIBA_AuthEvent_Bound(auth_req_id, code) @ #i
            & #j < #i)"

lemma CIBA2_complete_after_request:
    all-traces
    "All ClientID #i. AS_Auth_Completed(ClientID) @ #i
     ==> (Ex auth_req_id #j #k.
            UserAuth_Initiated(auth_req_id) @ #j
            & ASOnly_AuthReq_ClientID_Action(auth_req_id, ClientID) @ #k
            & #k < #j
            & #j < #i)"

lemma CIBA3_auth_req_id_unique:
    all-traces
    "All id #i #j.
       AS_UserAuthAccepted(id) @ #i & AS_UserAuthAccepted(id) @ #j
       ==> #i = #j"

lemma CIBA4_auth_event_binding:
    all-traces
    "All id code1 code2 #i #j.
       CIBA_AuthEvent_Bound(id, code1) @ #i
       & CIBA_AuthEvent_Bound(id, code2) @ #j
       ==> #i = #j"

lemma CIBA5_code_single_issuance:
    all-traces
    "All id #i #j.
       CIBA_Code_Issued(id) @ #i & CIBA_Code_Issued(id) @ #j
       ==> #i = #j"

lemma CIBA6_no_unsolicited_auth:
    all-traces
    "All auth_req_id #i.
       AS_UserAuthAccepted(auth_req_id) @ #i
       ==> (Ex ClientID #j.
              ASOnly_AuthReq_ClientID_Action(auth_req_id, ClientID) @ #j
              & #j < #i)"

lemma CIBA7_poll_authorized_implies_user_auth:
    all-traces
    "All auth_req_id #i.
       AS_Request_Accepted(<'poll_authorized', auth_req_id>) @ #i
       ==> (Ex #j. AS_UserAuthAccepted(auth_req_id) @ #j & #j < #i)"

lemma CIBA8_code_requires_poll[hide_lemma=R2_dpop_requires_creation,
   hide_lemma=B1_attestation_unforgeable,
   hide_lemma=B2_as_requires_attestation,
   hide_lemma=B3_token_implies_attestation,
   hide_lemma=accept_implies_hardware,
   hide_lemma=I1_token_requires_hardware_key]:
    all-traces
    "All auth_req_id #i.
       CIBA_Code_Issued(auth_req_id) @ #i
       ==> (Ex #j. CIBA_Poll_Sent(auth_req_id) @ #j & #j < #i)"

lemma CIBA9_auth_req_id_bound_to_client:
    all-traces
    "All auth_req_id ClientID1 ClientID2 #i #j.
       ASOnly_AuthReq_ClientID_Action(auth_req_id, ClientID1) @ #i
       & ASOnly_AuthReq_ClientID_Action(auth_req_id, ClientID2) @ #j
       ==> ClientID1 = ClientID2 & #i = #j"

end
